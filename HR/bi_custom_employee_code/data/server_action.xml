<odoo>

    <record id="employee_code_server_action" model="ir.actions.server">
        <field name="name">Generate Missing Employee Codes</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">records.action_assign_missing_emp_codes()</field>
    </record>
    <record id="employee_name_server_action" model="ir.actions.server">
        <field name="name">Update Analytic Account Names with Employee Code</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">records.action_update_analytic_account_name()</field>
    </record>
    
</odoo>

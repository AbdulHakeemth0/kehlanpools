<odoo>
    <data noupdate="0">
        <record id="end_of_service_provision_salary_rule_month" model="hr.salary.rule">
            <field name="name">End of Gratuity Provision Monthly</field>
            <field name="category_id" ref="hr_payroll.COMP"/>
            <field name="code">EGPM</field>
            <field name="appears_on_payslip">False</field>
            <field name="sequence">90</field>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
            <![CDATA[
if inputs.get('EGPM'):
    result = inputs['EGPM'].amount
else:
    result = 0
                 ]]>
            </field>
            <field name="struct_id" ref="hr_payroll.structure_002"/>
        </record>

        <record id="employee_emd_of_service_provision_month" model="hr.payslip.input.type">
            <field name="name">EGPM</field>
            <field name="code">EGPM</field>
            <field name="country_id" eval="False"/>
        </record>
    </data>

    <data noupdate="0">
        <record id="end_of_service_salary_rule_new" model="hr.salary.rule">
            <field name="name">Gratuity End of Service Payout</field>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="code">GEOS</field>
            <field name="sequence">80</field>
            <field name="condition_select">none</field>
            <field name="condition_python"></field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute"><![CDATA[
if inputs.get('GEOS'):
    result = inputs.get('GEOS').amount
else:
    result = 0
                 ]]></field>
            <field name="struct_id" ref="hr_payroll.structure_002"/>
        </record>

        <record id="end_of_service_salary__provision_rule_new" model="hr.payslip.input.type">
            <field name="name">GEOS</field>
            <field name="code">GEOS</field>
            <field name="country_id" eval="False"/>
        </record>
    </data>
</odoo>

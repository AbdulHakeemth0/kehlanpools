<odoo>
    <record id="view_gratuity_provision_form" model="ir.ui.view">
        <field name="name">gratuity.provision.form.view</field>
        <field name="model">gratuity.provision</field>
        <field name="arch" type="xml">
            <form>
                <sheet string="Gratuity Provision">
                    <group>
                        <group>
                            <field name="employee_id" />
                        </group>
                        <group>
                            <field name ="contract_state" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="gratuity_provision" string="Gratuity Provision">
                            <field name="gratuity_provision_line_ids">
                                <list string="Gratuity Provision" editable="bottom">
                                    <field name="year" />
                                    <field name ="experience"/>
                                    <field name="amount"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <record id="gratuity_provisionlist_inform" model="ir.ui.view">
        <field name="name">gratuity.provision.list</field>
        <field name="model">gratuity.provision</field>
        <field name="arch" type="xml">
            <list string="Insurance Entry">
                <field name="employee_id"/>
            </list>
        </field>
    </record>

    <!-- Action: Open Gratuity Provision Entry Form -->
    <record id="open_gratuity_provision_form" model="ir.actions.act_window">
        <field name="name">Gratuity Provision</field>
        <field name="res_model">gratuity.provision</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Item: Gratuity Entry -->
    <menuitem id="menu_order_provision"
              name="Gratuity Provision"
              action="open_gratuity_provision_form"
              parent="hr_payroll.menu_hr_payroll_payslips"
              sequence="10"
              />
</odoo>
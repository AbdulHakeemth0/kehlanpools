<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id='hr_department_skill_view_form' model='ir.ui.view'>
        <field name="name">hr.department.skill.view.form</field>
        <field name="model">hr.department.skill</field>
        <field name="arch" type="xml">
            <form string="Checklist">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_hr_department_skills" model="ir.actions.act_window">
        <field name="name">Department Skills</field>
        <field name="res_model">hr.department.skill</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_hr_department_skills"
        name="Dept. Skills"
        action="action_hr_department_skills"
        parent="hr.menu_config_employee"
        sequence="1"/>

</odoo>

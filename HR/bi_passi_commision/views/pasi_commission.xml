<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- pasi commition form view -->
    <record id="pasi_commission_view_form" model="ir.ui.view">
        <field name="name">pasi_commission_view_form</field>
        <field name="model">pasi.commission</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group name="gp_main">
                        <group name="gp_one">
                            <field name="employee_contribution" />
                            <field name="employer_contribution" />
                            <field name="company_id" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- pasi commission list view  -->
    <record id="pasi_commission_view_list" model="ir.ui.view">
        <field name="name">pasi.commission.view.list</field>
        <field name="model">pasi.commission</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_contribution" />
                <field name="employer_contribution" />
                <field name="company_id"/>
            </list>
        </field>
    </record>
    <!-- pasi commission action -->
    <record id="pasi_commission_action" model="ir.actions.act_window">
        <field name="name">Passi Commision</field>
        <field name="res_model">pasi.commission</field>
        <field name="view_mode">list,form</field>
    </record>
    <!-- pasi commission menuitem  -->
    <menuitem
        id="pasi_commission_menuitem"
        name="Passi Commission"
        action="pasi_commission_action"
        parent="hr_work_entry_contract_enterprise.menu_hr_payroll_configuration"
        sequence="3"/>
</odoo>

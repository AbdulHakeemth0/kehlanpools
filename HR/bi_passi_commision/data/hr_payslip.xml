<odoo>
    <data noupdate="0">
        <record id="employee_contribution_salary_deducion_rule" model="hr.salary.rule">
            <field name="name">Employee Contribution</field>
            <field name="category_id" ref="hr_payroll.COMP"/>
            <field name="code">EDS</field>
            <field name="appears_on_payslip">False</field>
            <field name="sequence">90</field>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute"><![CDATA[
if inputs.get('EDS'):
    result = inputs.get('EDS').amount
else:
    result = 0
]]>
            </field>
            <field name="struct_id" ref="hr_payroll.structure_002"/>
        </record>

        <record id="employee_contribution_salary_deduction" model="hr.payslip.input.type">
            <field name="name">EDS</field>
            <field name="code">EDS</field>
            <field name="country_id" eval="False"/>
        </record>

        <record id="employee_salary_contribution_rule" model="hr.salary.rule">
            <field name="name">Employer Contribution</field>
            <field name="category_id" ref="hr_payroll.COMP"/>
            <field name="code">ECS</field>
            <field name="appears_on_payslip">False</field>
            <field name="sequence">90</field>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute"><![CDATA[
if inputs.get('ECS'):
    result = inputs.get('ECS').amount
else:
    result = 0
]]>
            </field>
            <field name="struct_id" ref="hr_payroll.structure_002"/>
        </record>

        <record id="employee_emd_of_service_provision_month" model="hr.payslip.input.type">
            <field name="name">ECS</field>
            <field name="code">ECS</field>
            <field name="country_id" eval="False"/>
        </record>
    </data>
</odoo>
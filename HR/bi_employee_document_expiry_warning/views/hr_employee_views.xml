<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!--Inherit Documents super button for hr_employee button-->
    <record id="view_employee_form_doc_expiry_custom" model="ir.ui.view">
        <field name="name">hr.employee.view.form.inherit.employee.documents.expiry</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <div class="oe_button_box" position="inside">
                <button class="oe_stat_button" name="document_view"
                        type="object" icon="fa-list-ol">
                    <field string="Documents" name="document_count_custom"
                           widget="statinfo"/>
                </button>
            </div>
            <!-- Documents smart button made invisible which is in odoo default-->
            <xpath expr="//button[@name='action_open_documents']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>

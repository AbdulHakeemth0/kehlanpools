<odoo>

    <record id="hr_advance_salary_rule" model="hr.salary.rule">
        <field name="name">Advance Salary</field>
        <field name="sequence" eval="10"/>
        <field name="code">ADV100</field>
        <field name="category_id" ref="hr_payroll.DED"/>
        <field name="condition_select">none</field>
        <field name="amount_select">code</field>
        <field name="amount_python_compute"><![CDATA[
if inputs.get('ADV100'):
    result = inputs.get('ADV100').amount
else:
    result = 0
]]>
            </field>
        <field name="struct_id" ref="hr_payroll.structure_002"/>
    </record>

    <record id="advance_s_rl" model="hr.payslip.input.type">
        <field name="name">ADV100</field>
        <field name="code">ADV100</field>
        <field name="country_id" eval="False"/>
    </record>

</odoo>
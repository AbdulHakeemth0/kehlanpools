<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id='bi_overtime_form_view' model='ir.ui.view'>
        <field name="name">Bi Overtime Form View</field>
        <field name="model">bi.overtime</field>
        <field name="arch" type="xml">
            <form >
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="overtime_type"/>
                        <field name="first_check_in" />
                        <field name="last_check_out" />
                        <field name="ot_hours" />
                        <field name="overtime_pay"/>
                        <field name="number" invisible='1'/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="bi_overtime_list_view" model="ir.ui.view">
        <field name="name">Bi Overtime List view</field>
        <field name="model">bi.overtime</field>
        <field name="arch" type="xml">
            <list string="Overtime" create="0" edit="0">
                <field name="employee_id" readonly="1"/>
                <field name="overtime_type" readonly="1"/>
                <field name="first_check_in" readonly="1"/>
                <field name="last_check_out" readonly="1"/>
                <field name="ot_hours" widget="float_time" readonly="1"/>
                <field name="overtime_pay" readonly="1"/>
            </list>
        </field>
    </record>

    <record id="action_bi_overtime" model="ir.actions.act_window">
        <field name="name">Overtime</field>
        <field name="res_model">bi.overtime</field>
        <field name="view_id" ref="bi_overtime_list_view"/>
    </record>

    <menuitem
            id="menu_bi_overtime"
            name="Overtime"
            parent="hr_attendance.menu_hr_attendance_root"
            action="action_bi_overtime"
            sequence="7"/>

</odoo>

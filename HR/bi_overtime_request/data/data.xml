<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <!-- Normal OT Input Type -->
        <record id="input_type_normal_ot" model="hr.payslip.input.type">
            <field name="name">Normal OT</field>
            <field name="code">NORMAL_OT</field>
            <field name="country_id" eval="False"/>
        </record>

        <!-- Holiday OT Input Type -->
        <record id="input_type_holiday_ot" model="hr.payslip.input.type">
            <field name="name">Holiday OT</field>
            <field name="code">HOLIDAY_OT</field>
            <field name="country_id" eval="False"/>
        </record>

        <!-- Salary Rule for Normal OT -->
        <record id="salary_rule_normal_ot" model="hr.salary.rule">
            <field name="name">Normal OT</field>
            <field name="sequence" eval="12"/>
            <field name="code">NORMAL_OT</field>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
                <![CDATA[
if inputs.get('NORMAL_OT'):
    result = inputs.get('NORMAL_OT').amount
else:
    result = 0
                 ]]>
            </field>
            <field name="struct_id" ref="hr_payroll.structure_002"/>
        </record>

        <!-- Salary Rule for Holiday OT -->
        <record id="salary_rule_holiday_ot" model="hr.salary.rule">
            <field name="name">Holiday OT</field>
            <field name="sequence" eval="10"/>
            <field name="code">HOLIDAY_OT</field>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
                <![CDATA[
if inputs.get('HOLIDAY_OT'):
    result = inputs.get('HOLIDAY_OT').amount
else:
    result = 0
                ]]>
            </field>
            <field name="struct_id" ref="hr_payroll.structure_002"/>
        </record>
    </data>
</odoo>
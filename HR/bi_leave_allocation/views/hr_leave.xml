<odoo>

    <data>
        <record id="view_leave_form_view_inherit" model="ir.ui.view">
            <field name="name">hr.leave.form.view.inherit</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_manager"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="leave_salary_action" type="object" string="Apply Leave Salary" class="oe_highlight"
                        invisible="is_full_leave_salary or is_partial_leave_salary"/>
                </xpath>
                <xpath expr="//field[@name='name']" position='after'>
                    <field name="annual_leave_salary" readonly="1"/>
                    <field name="is_leave_annual" invisible="1"/>
                    <field name="is_full_leave_salary" invisible="1"/>
                    <field name="is_partial_leave_salary" invisible="1"></field>
                </xpath>
                <xpath expr="//field[@name='employee_id']" position="after">
                    <field name="leave_salary_type" readonly="1"/>
                </xpath>
            </field>
        </record>

        <record id="hr_leave_view_tree_inherit_annual_leave_sal" model="ir.ui.view">
        <field name="name">annual.leave.view.list.inherit.list</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_tree"/>
        <field name="mode">extension</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="annual_leave_salary" readonly="1"/>
            </xpath>
        </field>
        </record>

        <!-- <record id="hr_leave_view_tree1_inherit_annual_leave_sal" model="ir.ui.view">
            <field name="name">annual.leave.view.list.inherit.tree</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_view_tree_my"/>
            <field name="mode">primary</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='date_to']" position="before">
                    <field name="annual_leave_salary" readonly="1"/>
                </xpath>
            </field>
        </record> -->
        
        <record id="hr_leave_view_form_inherited_view" model="ir.ui.view">
        <field name="name">hr.leave.view.form.inherited</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_approve']" position="replace">
                <button string="Approve" name="action_approve" type="object" class="oe_highlight" invisible="not can_approve or state != 'confirm' or is_full_leave_salary"/>
            </xpath>
        </field>
    </record>
    </data>
</odoo>

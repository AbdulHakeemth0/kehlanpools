<odoo>
    <record id="view_petty_cash_request_form" model="ir.ui.view">
        <field name="name">petty.cash.request.form</field>
        <field name="model">petty.cash.request</field>
        <field name="arch" type="xml">
            <form string="Petty Cash Request">
                <header>
                    <button class="oe_highlight" invisible="state not in ['draft','reject']" name="action_approve_request"
                            string="Request For Approval" type="object"/>
                    <!-- <button class="oe_highlight"  name="action_coo_approve_request"
                            string="Manager" type="object" invisible="state not in ['manager_approval']"/> -->
                    <button class="oe_highlight"
                            name="action_ceo_approve_request" string="COO" type="object" invisible="state not in ['coo_approval']"/>
                    <button class="oe_highlight"
                            name="action_ceo_approved" string="CEO" type="object" invisible="state not in ['ceo_approval']"/>
                    <button class="btn-danger"
                            name="action_reject" string="Reject" type="object" invisible="state in ['draft','reject']"/>
                    <!-- <button class="oe_highlight"
                            name="button_cancel_entry" string="Cancel" type="object" invisible="state in ('cancel','reject')"/> -->
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                <label for="request_number" invisible="1" string="Petty Cash No."/>
                    <h1>
                        <field name="request_number" readonly="1"/>
                    </h1>
                <group>
                    <group>
                        <field name="statement_no"/>
                        <field name="narration"/>
                        <field name="company_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="requested_date" readonly="1"/>
                        <field name="total_amount" readonly="1"/>
                        <field name="currency_id" readonly="1"/>
                        <field name="reject_reason" readonly="state in ('reject','draft')"/>
                    </group>
                </group>
                    <notebook>
                        <page string="Expenses">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="particulars"/>
                                    <field name="attachment_ids" widget="many2many_binary"/>
                                    <field name="supplier_id" column_invisible="1"/>
                                    <field name="supplier_name"/>
                                    <field name="reference"/>
                                    <field name="division"/>
                                    <field name="amount"/>
                                    <field name="rejected" invisible="rejected == False"/>
                                    <button name="action_reject_line"
                                            type="object"
                                            string="Reject"
                                            class="btn-danger"
                                            invisible="rejected == True"/>  
                                </list>
                            </field>
                        </page>
                        <page id="approval_tab" string="Approvals" name="approval_info">
                        <group>
                            <group>
                                <field name="prepared_by"/>
                                <!-- <field name="approval1"/>
                                <field name="approval1_name" invisible="not approval1"/> -->
                            <!-- </group>
                            <group> -->
                                <!-- <field name="approval2"/> -->
                                <field name="received_by"/>
                                <field name="approval2_name"/>
                            </group>
                        </group>
                        </page>
                        </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_petty_cash_request_list" model="ir.ui.view">
        <field name="name">petty.cash.request.list</field>
        <field name="model">petty.cash.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="request_number"/>
                <field name="state"/>
                <field name="total_amount"/>
            </list>
        </field>
    </record>

    <record id="action_petty_cash_request" model="ir.actions.act_window">
        <field name="name">Petty Cash Requests</field>
        <field name="res_model">petty.cash.request</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_petty_cash_request_list"/>
        <field name="help" type="html">
            <p>
                Petty Cash Requests
            </p></field>
    </record>

</odoo>

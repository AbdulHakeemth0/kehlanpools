<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>
        <record id="account_statement_wizard_view_form" model="ir.ui.view">
            <field name="name">account.statement.wizard.view.form</field>
            <field name="model">account.statement.wizard</field>
            <field name="arch" type="xml">
                <form string="Account Statement">
                    <sheet>
                        <group>
                            <group>
                                <field name="partner_id" invisible="not context.get('is_customer')" domain="[('parent_id', '=', False), ('customer_rank', '>', 0)]" string="Customer" required="1"/>
                                <field name="partner_id" invisible="not context.get('is_vendor')" domain="[('parent_id', '=', False), ('supplier_rank', '>', 0)]" string="Vendor" required="1"/>
                                <field name="date_start" required="1"/>
                                <field name="date_end" required="1"/>
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button string="PRINT" name="print_pdf" type="object" class="oe_highlight"/>
                        <button string="PRINT EXCEL" name="print_followup_report_xlsx" type="object" class="oe_highlight"/>
                        <button string="CANCEL" class="oe_link" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="account_statement_wizard_action" model="ir.actions.act_window">
            <field name="name">Account Statement Wizard</field>
            <field name="res_model">account.statement.wizard</field>
            <field name="view_mode">form</field>
            <field name="context">{'is_customer': True}</field>
<!--            <field name="domain">[("parent_id", "=", False), ("customer_rank", "!=", 0)]</field>-->
            <field name="target">new</field>
        </record>

        <record id="vendor_account_statement_wizard_action" model="ir.actions.act_window">
            <field name="name">Vendor Account Statement Wizard</field>
            <field name="res_model">account.statement.wizard</field>
            <field name="view_mode">form</field>
            <field name="context">{'is_vendor': True}</field>
<!--            <field name="domain">[("parent_id", "=", False), ("supplier_rank", "!=", 0)]</field>-->
            <field name="target">new</field>
        </record>

        <menuitem
            id="account_statement_wizard_menu"
            name="Customer Account Statement"
            action="account_statement_wizard_action"
            parent="account.menu_finance_receivables"
            sequence="19"/>

        <menuitem
            id="vendor_account_statement_wizard_menu"
            name="Vendor Account Statement"
            action="vendor_account_statement_wizard_action"
            parent="account.menu_finance_payables"
            sequence="19"/>
    </data>

</odoo>

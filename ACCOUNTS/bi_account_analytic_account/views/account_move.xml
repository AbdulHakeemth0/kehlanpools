<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_account_move_inh_form" model="ir.ui.view">
            <field name="name">account.move.amc.vas</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//label[@for='invoice_date']" position="before">
                    <field name="type" string="Type" style="font-weight:bold;" invisible="move_type not in ('out_invoice')"/>
                    <field name="job_no" style="font-weight:bold;"/>
                    <field name="m_number" groups="base.group_no_one"/>
                    <field name="lpo_no" style="font-weight:bold;"/>
                    <field name="adv_amount_received" style="font-weight:bold;"/>
                    <!-- <field name="type" string="Type" style="font-weight:bold;" invisible="move_type not in ('out_invoice')" required="move_type not in ('out_invoice')"/> -->
                </xpath>
                <xpath expr="//field[@name='partner_shipping_id']" position="after">
                   <field name="invoicing_percentage" force_save="1"/>
                   <field name="acc_type" force_save="1" invisible="move_type not in ('entry')"/>
                </xpath>
                <xpath expr="//field[@name='show_update_fpos']" position="after">
                    <div class="oe_title">
                        <h1>
                            <field name="sequence_no" invisible="1" readonly="1"/>
                        </h1>
                    </div>
                </xpath>
                <xpath expr="//field[@name='name']" position="attributes">
                    <attribute name="readonly">1</attribute>
                </xpath>
                <xpath expr="//field[@name='invoice_user_id']" position="after">
                    <field name="delivery_note"/>
                    <field name="quotation_ref"/>
                    <field name="terms_of_pay"/>
                    <field name="other_ref"/>
                    <field name="buyers_order_no"/>
                    <field name="desp_through"/>
                    <field name="dest"/>
                    <field name="terms_of_del"/>
                </xpath>
            </field>
        </record>

        <record id="acc_view_out_invoice_tree_inherited" model="ir.ui.view">
            <field name="name">account.move.custom.invoice.list.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_out_invoice_tree"/>
            <field name="arch" type="xml">
                <field name="name" position="before">
                    <field name="sequence_no" column_invisible="1"/>
                </field>
                <field name="invoice_date" position="after">
                    <field name="m_number"/>
                </field>
            </field>
        </record>

        <!-- m_number search in search filter -->
        <record id="account_move_view_search_inherited" model="ir.ui.view">
            <field name="name">account.move.view.search</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_invoice_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="before">
                    <field name="m_number"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
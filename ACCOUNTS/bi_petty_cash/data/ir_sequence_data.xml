<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="seq_petty_cash_expenses_ho" model="ir.sequence">
            <field name="name">Petty Cash Expenses</field>
            <field name="code">petty.cash.expenses.ho</field>
            <field name="prefix">PCE%(y)s</field>
            <field name="padding">6</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <record id="seq_petty_cash_imbursement" model="ir.sequence">
            <field name="name">Petty Cash Imbursement</field>
            <field name="code">code.imbursement</field>
            <field name="prefix">PCI-%(y)-s-</field>
            <field name="padding">3</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <record id="seq_petty_cash_transfer" model="ir.sequence">
            <field name="name">Petty Cash Transfer</field>
            <field name="code">code.transfer</field>
            <field name="prefix">PCT-%(y)-s-</field>
            <field name="padding">3</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

    </data>
</odoo>

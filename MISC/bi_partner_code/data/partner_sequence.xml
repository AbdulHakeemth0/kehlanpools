<odoo noupdate="1">

    <!-- customer/debtor code -->
    <record id="seq_customer_code" model="ir.sequence">
        <field name="name">Customer Code Sequence</field>
        <field name="code">res.partner.customer_code</field>
        <field name="prefix">DEB</field>
        <field name="padding">3</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <!-- vendor/creditor code -->
    <record id="seq_vendor_code" model="ir.sequence">
        <field name="name">Vendor Code Sequence</field>
        <field name="code">res.partner.vendor_code</field>
        <field name="prefix">CRE</field>
        <field name="padding">3</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

</odoo>

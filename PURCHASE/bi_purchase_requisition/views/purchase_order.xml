<odoo>
    <data>
      <record id="view_purchase_order_inherit_form_1" model="ir.ui.view">
          <field name="name">view.purchase.order.inherit.form_1</field>
          <field name="model">purchase.order</field>
          <field name="inherit_id" ref="purchase.purchase_order_form" />
          <field name="arch" type="xml">
              <xpath expr="//field[@name='partner_id']" position="after">
                <field name='m_number'/>
                <field name="job_number"/>
                <field name="attention"/>
                <field name="mr_remarks"/>
                <field name="bi_custom_state" invisible="1"/>
                <field name="material_req_id" invisible="1"/>
              </xpath> 
              <xpath expr="//field[@name='project_id']" position="attributes">
                <attribute name="invisible">1</attribute>
              </xpath>
              <xpath expr="//button[@id='bid_confirm']" position="attributes">
                <attribute name="groups">bi_purchase_requisition.po_approval_group</attribute>
              </xpath>
              <xpath expr="//button[@id='draft_confirm']" position="attributes">
                <attribute name="groups">bi_purchase_requisition.po_approval_group</attribute>
              </xpath>
              <xpath expr="//button[@id='draft_confirm']" position="after">
                <button class="oe_highlight" invisible="1" name="print_rfq" string="RFQ Print" type="object"/>
              </xpath>
              <xpath expr="//button[@id='draft_confirm']" position="after">
                <button class="oe_highlight" invisible="state not in ['purchase']" name="print_po" string="PO Print" type="object"/>
              </xpath>
              <xpath expr="//button[@name='print_quotation']" position="attributes">
                <attribute name="invisible">1</attribute>
              </xpath>
              <xpath expr="//button[@name='print_quotation'][2]" position="attributes">
                <attribute name="invisible">1</attribute>
              </xpath>
          </field>
      </record>
    </data>
  </odoo>

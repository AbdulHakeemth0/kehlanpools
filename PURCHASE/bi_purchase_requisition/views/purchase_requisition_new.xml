<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchasre_requsition_new_form" model="ir.ui.view">
        <field name="name">purchase.requisition.new.form</field>
        <field name="model">purchase.requisition.new</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button class="oe_highlight" invisible="state not in ['draft']" name="button_submit" string="Submit" type="object"/>
                    <!-- groups="bi_purchase_requisition.module_purchase_requisition_user" -->
                    <button class="oe_highlight" invisible="state not in ['submit']" name="button_reviewd" string="Reviewed" type="object"/>
                    <!-- groups="bi_purchase_requisition.module_purchase_requisition_reviewed" -->
                    <button class="oe_highlight" invisible="state not in ['reviewed']" name="button_validate" string="Validate" type="object"/>
                    <!-- groups="bi_purchase_requisition.module_purchase_requisition_validate"  -->
                    <button class="oe_highlight" invisible="state not in ['validate']" name="button_approve" string="Approve" type="object"/>
                    <!-- groups="bi_purchase_requisition.module_purchase_requisition_manager"  -->
                    <button name="button_cancel" string="Cancel" type="object"/>
                    <!-- groups="bi_purchase_requisition.module_purchase_requisition_user" -->
                    <field name="state" readonly="1" statusbar_visible="draft,submit,reviewed,validate,approved" widget="statusbar"/>
                </header>
                <sheet>
                    <div name="button_box" position="inside">
                        <button class="oe_stat_button" type="object" name="get_rfq" icon="fa-list-alt">
                            <field string="RFQ" name="rfq_order_ids" widget="statinfo" />
                        </button>
                    </div>

                <div class="oe_title">
                    <h1>
                        <field name="name" readonly="1"/>
                    </h1>
                </div>
                    <group>
                        <group>
                            <field name="partner_ref" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                            <!-- <field name="reason"/> -->
                            <field force_save="1" groups="base.group_multi_currency" invisible="1" name="currency_id"/>
                            <field name="vendor_id" widget="many2many_tags" readonly="state not in ('draft')" required ="1"/>
                            <field name="m_number" readonly="1"/>
                            <field name="job_number" readonly="1"/>
                            <!-- <field name="department_id" readonly="state not in ('draft')"/> -->
                        </group>
                        <group>
                            <field invisible="1" name="submitted_user_id"/>
                            <field invisible="1" name="reviewed_user_id"/>
                            <field invisible="1" name="approved_user_id"/>
                            <field name="date_order" readonly="1"/>
                            <field name="date_end" readonly="1"/>
                            <field name="payment_term_id" readonly="state not in ('draft')"/>
                            <field name="status_po" readonly = "1"/>
                            <field name="currency_id" invisible="1"/>
                            <!-- <field name="department_id" readonly="state == 'approved'"/> -->
                            <field groups="base.group_multi_company" name="company_id" options="{'no_create': True}" readonly="state not in ('draft')"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Products">
                            <button class="oe_highlight" name="select_line" string="select" type="object"/>
                            <field name="pr_approved_line" widget="one2many_selectable">
                                <list editable="bottom" string="PR Lines">
                                    <field column_invisible="1" name="currency_id"/>
                                    <field column_invisible="1" name="state"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="is_select"/>
                                    <field name ="product_id" readonly="state in ['approved']"/>
                                    <field name="name" readonly="state in ['approved']"/>
                                    <field name="product_uom" options="{'no_create_edit': True}" readonly="state in ['approved']"/>
                                    <!-- <field name="reason"/> -->
                                    <field column_invisible="1" name="date_planned" />
                                    <field column_invisible="1" groups="base.group_multi_company" name="company_id" options="{'no_create': True}"/>
                                    <field name="product_qty" readonly="state in ['approved']"/>
                                    <field name="price_unit" readonly="state in ['approved']"/>
                                    <field name="price_subtotal" widget="monetary" readonly="state in ['approved']"/>
                                </list>
                                <form string="PR Line">
                                    <sheet>
                                        <field column_invisible="1" name="state"/>
                                        <group>
                                            <group>
                                                <label for="product_qty"/>
                                                <div>
                                                    <field class="oe_inline" name="product_qty"/>
                                                    <span class="oe_inline">
                                                    </span>
                                                </div>
                                                <field name="price_unit"/>
                                            </group>
                                            <group>
                                                <field name="date_planned" widget="date"/>
                                                <field colspan="2" groups="analytic.group_analytic_accounting" name="account_analytic_id"/>
                                                <field groups="analytic.group_analytic_accounting" name="analytic_tag_ids" options="{'color_field': 'color'}" widget="many2many_tags"/>
                                                <field groups="base.group_multi_company" name="company_id" options="{'no_create': True}"/>
                                            </group>
                                        </group>
                                        <notebook>
                                            <page string="Notes">
                                                <field name="name"/>
                                            </page>
                                        </notebook>
                                    </sheet>
                                    
                                </form></field>
                                <group class="oe_subtotal_footer oe_right oe_inline o_td_label">
                                    <div class="oe_subtotal_footer oe_right o_td_label">
                                        <label for="amount_total"/>
                                    </div>
                                <strong><field  name="amount_total" nolabel="1" options="{'currency_field': 'currency_id'}" widget="monetary"/></strong>
                                </group>
                            <field class="oe_inline" name="notes" placeholder="Define your terms and conditions ..." readonly="state == 'approved'"/>
                            <div class="oe_clear"/>
                        </page>
                        <page name="purchase_delivery_invoice" string="Other Information">
                            <group>
                                <group>
                                    <field name="user_id" readonly="state == 'approved'"/>
                                    <field name="payment_term_id" options="{'no_open': True, 'no_create': True}" readonly="state == 'approved'"/>
                                    <field name="fiscal_position_id" options="{'no_create': True}" readonly="state == 'approved'"/>
                                    <!-- <field name="date_approve" groups="base.group_no_one"/> -->
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form></field>
    </record>
    <record id="purchasre_requsition_new_tree" model="ir.ui.view">
        <field name="name">purchase.requisition.new.tree</field>
        <field name="model">purchase.requisition.new</field>
        <field name="arch" type="xml">
            <list decoration-bf="state=='approved'" decoration-danger="state=='draft'" decoration-muted="state == 'cancel'" default_order="name desc" string="Approved Purchase Requisition">
                <!-- decoration-info="state == 'rfq'" -->
                <field name="name" string="Requisition Number"/>
                <field name="date_order"/>
                <field name="partner_ref"/>
                <!-- <field name="department_id"/> -->
                <field groups="base.group_multi_company" name="company_id" options="{'no_create': True}"/>
                <field name="user_id"/>
                <field name="amount_total" sum="Total amount" widget="monetary"/>
                <field column_invisible="1" name="currency_id"/>
                <field name="state"/>
            </list></field>
    </record>
    <record id="purchasre_requsition_new_action" model="ir.actions.act_window">
        <field name="name">Purchase Requisition</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">purchase.requisition.new</field>
        <field name="view_mode">list,form</field>
        <!-- <field name="domain">[('state','=','approved')]</field> -->
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a purchase requisition
            </p></field>
    </record>

    <menuitem action="purchasre_requsition_new_action" id="menu_purchasre_requsition_new" name="Purchase Requisition" parent="purchase.menu_procurement_management" active="False" sequence="2"/>
</odoo>

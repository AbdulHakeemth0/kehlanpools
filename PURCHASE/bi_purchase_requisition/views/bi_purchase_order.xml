<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Bi purchase order Form -->
    <record id="bi_purchase_order_form_view" model="ir.ui.view">
        <field name="name">Bi Purchase Order</field>
        <field name="model">bi.purchase.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button class="oe_highlight" invisible="state not in ['draft']" name="confirm_rfq" groups="bi_purchase_requisition.purchase_rfq_user" string="Confirm MR" type="object"/>
                    <button class="oe_highlight"  invisible="state not in ['confirm']" groups="bi_purchase_requisition.purchase_rfq_manager" name="action_approve" string="Approve" type="object"/>
                    <button class="oe_highlight" invisible="state == 'cancel'" name="action_cancel" string="Cancel" type="object"/>
                    <button class="oe_highlight" invisible="state not in ['cancel']" groups="bi_purchase_requisition.purchase_rfq_manager" name="set_to_draft" string="Set To MR" type="object"/>
                    <field name="state" statusbar_visible="draft,confirm,approve,purchase,cancel" widget="statusbar"/>
     
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="get_purchase_quotation" icon="fa-list-alt" invisible="1">
                            <field string="Quotation's" name="bi_purchase_quotation_ids" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="get_purchase_order" icon="fa-list-alt">
                            <field string="PO's" name="bi_purchase_quotation_ids" widget="statinfo"/>
                        </button>
                    </div>
                    <!-- <span class="o_form_label" invisible="state in ('draft', 'sent')">
                        Purchase Order
                    </span> -->
                    <h1>
                        <field name="name" readonly="1"/>
                    </h1>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="partner_id" invisible = "1"/>
                            <!-- <field name="contact_ids" widget="many2many_tags"/> -->
                            <field name="origin" readonly="1" invisible = "1"/>
                            <field name="vendor_id" widget="many2many_tags" readonly="1" invisible = "1"/>
                            <field name="partner_ref" readonly="state not in ('draft')" invisible = "1"/>
                            <field invisible="1" name="revised_count"/>
                            <field invisible="1" name="old_name"/>
                            <field name="m_number"/>
                            <field name="job_type"/>
                            <field name="job_number" invisible ="job_type not in ('job')"/>
                            <field name="requested_by"/>
                        </group>
                        <group>
                            <field name="date_order"/>
                            <field invisible="1" name="company_id" readonly="state not in ('draft')"/>
                            <field name="currency_id" invisible = "1"/>
                            <field name="payment_term_id" invisible = "1" />
                            <field name="delivery_date"/>
                            <field class="oe_inline" name="notes"  placeholder="Define Remarks ..."/>
                        </group>
                    </group>
                    <notebook>
                        <page name="bi_purchase_line" string="Product Details">
                            <button class="oe_highlight" name="select_line" string="select" type="object" invisible="state not in ('approve','purchase')"/>
                            <field name="order_line" widget="section_and_note_one2many">
                                <list editable="bottom" string="Purchase Order Lines">
                                    <control>
                                        <create name="add_product_control" string="Add a product"/>
                                        <create context="{'default_display_type': 'line_section'}" name="add_section_control" string="Add a section"/>
                                        <create context="{'default_display_type': 'line_note'}" name="add_note_control" string="Add a note"/>
                                    </control>
                                    <field name="is_select"/>
                                    <field column_invisible="1" name="display_type"/>
                                    <field name="sequence" widget="handle"/>
                                    <field column_invisible="1" name="state"/>
                                    <field name="product_id"  readonly="state in ('approve')"/>
                                    <field name="name" widget="section_and_note_text"  readonly="state in ('approve')"/>
                                    <!-- <field name="product_uom" domain = "is_uom_domain" readonly="state in ('approve')"/> -->
                                    <field name="product_uom" domain="[('id','in',is_uom_domain_ids)]" readonly="state in ('approve')"/>
                                    <field name="is_uom_domain_ids" column_invisible="1"/>
                                    <field name="product_qty"  readonly="state in ('approve')" required="1"/>
                                    <field name="qty_done" readonly="1"/>
                                    <field name="price_unit"  readonly="state in ('approve')" column_invisible="1"/>
                                    <field name="discount"  readonly="state in ('approve')" column_invisible="1"/>
                                    <field name="taxes_id" widget="many2many_tags"  readonly="state in ('approve')" column_invisible="1"/>
                                    <field name="price_subtotal"  readonly="state in ('approve')" column_invisible="1"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list></field>
                            <group class="oe_subtotal_footer oe_right">
                                <field invisible="1" name="amount_untaxed" options="{'currency_field': 'currency_id'}" widget="monetary"/>
                                <field name="amount_tax" invisible="1" options="{'currency_field': 'currency_id'}" widget="monetary"/>
                                <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                                    <label for="amount_total" invisible="1"/>
                                </div>
                                <field class="oe_subtotal_footer_separator" invisible="1" name="amount_total" nolabel="1" options="{'currency_field': 'currency_id'}" widget="monetary"/>
                            </group>
                            
                            <div class="oe_clear" invisible="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="bi_purchase_order_view_tree" model="ir.ui.view">
        <field name="name">Bi Purchase Order</field>
        <field name="model">bi.purchase.order</field>
        <field name="arch" type="xml">
            <list string="Purchase Order">
                <field name="name"/>
                <field name="partner_id" column_invisible = "1"/>
                <!-- <field name="origin"/> -->
                <field name="user_id" optional="show"/>
                <field name="m_number" optional="show"/>
                <field name="job_type" optional="show"/>
                <field name="job_number" optional="show"/>
                <field name="date_order"/>
                <field name="delivery_date"/>
                <field name="requested_by" optional="show"/>
                <field name="partner_id" column_invisible = "1"/>
                <field column_invisible="1" name="company_id"/>
                <field name="notes" optional="show"/>
                <field name="state"/>
            </list>
        </field>
    </record>
    <record id="custom_purchase_order_type_kanban" model="ir.ui.view">
        <field name="name">bi.purchase.order.type.kanban</field>
        <field name="model">bi.purchase.order</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>

                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="o_kanban_record_top ">
                                <div class="o_kanban_record_headings mt4">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                </div>

                            </div>
                        </div>
                    </t>
                </templates>
            </kanban></field>
    </record>
    <record id="bi_purchase_order_kanban" model="ir.ui.view">
        <field name="name">bi.purchase.order.kanban</field>
        <field name="model">bi.purchase.order</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="state"/>
                <field name="partner_id"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings mt4">
                                    <strong class="o_kanban_record_title">
                                        <span>
                                            <field name="name"/>
                                        </span>
                                    </strong>
                                </div>
                                <field name="state" options="{'classes': {'draft': 'default', 'in_progress': 'default', 'open': 'success', 'done': 'success', 'close': 'danger'}}" readonly="1" widget="label_selection"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <span class="text-muted">
                                    <field name="partner_id" invisible = "1"/>
                                </span>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="bi_purchase_order_action" model="ir.actions.act_window">
        <field name="name">Material Request</field>
        <field name="res_model">bi.purchase.order</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new record
            </p></field>
    </record>
    <menuitem action="bi_purchase_order_action" groups="bi_purchase_requisition.purchase_rfq_user" id="bi_purchase_order_menu" name="Material Request" parent="purchase.menu_procurement_management" sequence="3"/>
    <!-- Bi Purchase Order Form Ends -->
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Bi purchase quotation Form -->
    <record id="bi_purchase_quotation_form_view" model="ir.ui.view">
        <field name="name">Bi Purchase Quotation</field>
        <field name="model">bi.purchase.quotation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button class="btn-primary" invisible="state not in ['draft']" name="confirm_quotation" string="Confirm Quotation" type="object"/>
                    <button class="oe_highlight"  invisible="state not in ['confirm']" name="action_approve" string="Approve" type="object"/>
                    <button class="oe_highlight" name="action_approve_2nd" string="Approve" type="object" invisible="1"/>
                    <button class="oe_highlight"  invisible="state not in ['quotation']" name="action_create_po" groups="purchase.group_purchase_manager" string="Create Purchase Order" type="object"/>
                    <button class="btn-primary" invisible="state == 'cancel'" name="action_cancel" string="Cancel" type="object"/>
                    <button class="btn-primary" invisible="state not in ['cancel']" name="set_to_draft" string="Set To Draft" type="object"/>
                    <button class="oe_highlight" name="send_rfq_bymail" string="Send By Mail" type="object"/>
                    <field name="state" statusbar_visible="draft,confirm,quotation,purchase,cancel" widget="statusbar"/>
                </header>
                <sheet>

                    <div name="button_box" position="inside">
                        <button class="oe_stat_button" type="object" name="get_purchase_order" icon="fa-list-alt">
                            <field string="Purchase" name="purchase_id" widget="statinfo"/>
                        </button>
                    </div>
                    <!-- <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-list-alt" invisible="state != 'purchase'" name="action_po_list" string="Purchase" type="object">
                        </button>
                    </div> -->
                    <span class="o_form_label" invisible="state in ('draft', 'sent')">
                        Purchase Quotation
                    </span>
                    <h1>
                        <field name="name" readonly="1"/>
                    </h1>
                    <group>
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <!-- <field name="contact_ids" widget="many2many_tags"/> -->
                            <field name="origin" readonly="1" />
                            <field name="partner_ref" readonly="state not in ('draft')"/>
                            <field name="m_number" readonly="1" />
                            <field name="job_number" readonly="1" />
                            <field invisible="1" name="revised_count"/>
                            <field invisible="1" name="old_name"/>
                        </group>
                        <group>
                            <field name="date_order" readonly="1"/>
                            <field invisible="1" name="company_id" readonly="state not in ('draft')"/>
                            <field name="currency_id" invisible = "1"/>
                            <field name="payment_term_id" readonly="state not in ('draft')"/>
                            <field name="delivery_date"  readonly="state not in ('draft')"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="bi_purchase_line" string="Product Details">
                            <field name="quotation_line" readonly="state in ('purchase', 'cancel')" widget="section_and_note_one2many">
                                <list editable="bottom" string="Purchase Quotation Lines">
                                    <control>
                                        <create name="add_product_control" string="Add a product"/>
                                        <create context="{'default_display_type': 'line_section'}" name="add_section_control" string="Add a section"/>
                                        <create context="{'default_display_type': 'line_note'}" name="add_note_control" string="Add a note"/>
                                    </control>
                                    <field column_invisible="1" name="display_type"/>
                                    <field name="sequence" widget="handle"/>
                                    <field column_invisible="1" name="state"/>
                                    <field name="product_id"/>
                                    <field name="name" widget="section_and_note_text"/>
                                    <field name="product_qty"/>
                                    <field column_invisible="1" name="product_uom_category_id"/>
                                    <field name="product_uom" options="{'no_create_edit': True}"/>
                                    <field name="price_unit"/>
                                    <field name="discount"/>
                                    <field name="taxes_id" widget="many2many_tags"/>
                                    <field name="price_subtotal"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list></field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="amount_untaxed" options="{'currency_field': 'currency_id'}" widget="monetary"/>
                                <field name="amount_tax" options="{'currency_field': 'currency_id'}" widget="monetary"/>
                                <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                                    <label for="amount_total"/>
                                </div>
                                <field class="oe_subtotal_footer_separator" name="amount_total" nolabel="1" options="{'currency_field': 'currency_id'}" widget="monetary"/>
                            </group>
                            <field class="oe_inline" name="notes" placeholder="Define your terms and conditions ..."/>
                            <div class="oe_clear"/>
                        </page>
                        <page name="other_information" string="Other Information">
                            <group>
                                <group>
                                    <field name="payment_term_id" readonly="state not in ('draft')"/>
                                    <field name="employee_id" readonly="state not in ('draft')"/>
                                    <field name="mob" readonly="state not in ('draft')"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="bi_purchase_quotation_view_tree" model="ir.ui.view">
        <field name="name">Bi Purchase Quotation</field>
        <field name="model">bi.purchase.quotation</field>
        <field name="arch" type="xml">
            <list  string="Purchase Quotation">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="amount_total"/>
                <field name="origin"/>
                <field name="date_order"/>
                <field name="delivery_date"/>
                <field column_invisible="1" name="company_id"/>
                <field name="state"/>
            </list></field>
    </record>
    <record id="custom_purchase_order_type_kanban" model="ir.ui.view">
        <field name="name">bi.purchase.order.type.kanban</field>
        <field name="model">bi.purchase.order</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>

                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="o_kanban_record_top ">
                                <div class="o_kanban_record_headings mt4">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                </div>

                            </div>
                        </div>
                    </t>
                </templates>
            </kanban></field>
    </record>
    <record id="bi_purchase_order_kanban" model="ir.ui.view">
        <field name="name">bi.purchase.order.kanban</field>
        <field name="model">bi.purchase.order</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="state"/>
                <field name="partner_id"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings mt4">
                                    <strong class="o_kanban_record_title">
                                        <span>
                                            <field name="name"/>
                                        </span>
                                    </strong>
                                </div>
                                <field name="state" options="{'classes': {'draft': 'default', 'in_progress': 'default', 'open': 'success', 'done': 'success', 'close': 'danger'}}" readonly="1" widget="label_selection"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <span class="text-muted">
                                    <field name="partner_id"/>
                                </span>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="bi_purchase_quotation_action" model="ir.actions.act_window">
        <field name="name">Purchase Quotation</field>
        <field name="res_model">bi.purchase.quotation</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new record
            </p></field>
    </record>
    <menuitem action="bi_purchase_quotation_action" id="bi_purchase_quotation_menu" name="Purchase Quotation" active="False" parent="purchase.menu_procurement_management" sequence="4"/>
    <!-- Bi Purchase Quotation Form Ends -->
</odoo>

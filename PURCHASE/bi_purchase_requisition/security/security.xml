<?xml version="1.0"?>
<odoo>
    <data noupdate="0">
        <record model="ir.module.category" id="purchase_rfq_access">
            <field name="name">Material Request</field>
            <field name="description">Purchase Request For Quotation</field>
            <field name="sequence">25</field>
        </record>

        <record model="res.groups" id="purchase_rfq_user">
            <field name="name">User</field>
            <field name="category_id" ref="purchase_rfq_access"/>
        </record>
        <record model="res.groups" id="purchase_rfq_manager">
            <field name="name">Manager</field>
            <field name="category_id" ref="purchase_rfq_access"/>
            <field name="implied_ids" eval="[(4, ref('bi_purchase_requisition.purchase_rfq_user'))]"/>
        </record>
        <record model="res.groups" id="po_approval_group">
            <field name="name">Po Approval</field>
            <field name="category_id" ref="purchase_rfq_access"/>
            <field name="implied_ids" eval="[(4, ref('bi_purchase_requisition.purchase_rfq_user'))]"/>
        </record>
    </data>
</odoo>


<odoo>
    <record id="view_picking_form_product_warranty" model="ir.ui.view">
        <field name="name">stock.picking.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='picking_type_id']" position="after">
                <field name="purchase_id" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='move_ids_without_package']/list/field[@name='quantity']" position="after">
                <field name="warranty" column_invisible="parent.picking_type_code == 'internal'"/>
                <field name="warranty_type" required="warranty > 0" column_invisible="parent.picking_type_code == 'internal'"/>
            </xpath>
            <!-- <xpath expr="//field[@name='move_ids_without_package']/tree/field[@name='quantity']" position="after">
                <field name="warranty" column_invisible="parent.picking_type_code == 'outgoing' or parent.picking_type_code == 'internal' or parent.purchase_id"/>
                <field name="warranty_type" column_invisible="parent.picking_type_code == 'outgoing' or parent.picking_type_code == 'internal' or parent.purchase_id"/>
            </xpath> -->
        </field>   
    </record>
</odoo>
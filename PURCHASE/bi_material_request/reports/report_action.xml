<odoo>
    <record id="material_request_report_action" model="ir.actions.report">
        <field name="name">Material Request Report</field>
        <field name="model">bi.purchase.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bi_material_request.material_request_template</field>
        <field name="report_file">bi_material_request.material_request_template</field>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Material Request - %s' % object.name</field>
        <field name="binding_model_id" ref="bi_purchase_requisition.model_bi_purchase_order"/>
        <field name="paperformat_id" ref="bi_material_request.material_request_paperformat"/>
    </record>
</odoo>
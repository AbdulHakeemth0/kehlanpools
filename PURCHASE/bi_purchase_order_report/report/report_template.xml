<odoo>
    <data>
        <!-- PO Printout -->
        <template id="purchase_order_print_template">
            <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="o">
                    <t t-call="bi_purchase_order_report.purchase_order_header"/>
                    <div class="page" id="all_page">
                        <table width="100%" style="border-collapse: collapse;">
                            <tr width="100%" height="50px">
                                  <span style="padding-left:650px; padding-top:-20%; font-size:13px;"><b>TRN:<t t-if="o.company_id">
                                    <t t-if="o.company_id.vat">
                                        <t t-esc="o.company_id.vat"/>
                                    </t>
                                    <t t-else="">
                                        NA
                                    </t>
                                    </t>
                                    </b></span>
                                <td style="text-align:center;border:1px solid  black;border-right:hidden;border-left:hidden;font-size:20px">
                                    <b>PURCHASE ORDER</b>
                                </td>
                            </tr>
                        </table>

                        <table width="100%" class="table table-sm table-borderless" style="font-size: 14px;border-collapse: collapse;">
                            <tr width="100%" style="line-height:20px;border-left:1px solid black;border-right:1px solid black;">
                                <td width="10%" style="font-weight: bold;padding-left:5px">To</td>
                                <td width="2%" style="text-align: center;">:</td>
                                <td width="40%" colspan="3" style="padding-left:5px;">
                                    <span t-if="o.partner_id">
                                        <span t-field="o.partner_id.name"/>
                                    </span>
                                </td>
                                <td width="15%" style="font-weight: bold;padding-left:5px;">Doc. No.</td>
                                <td width="2%">:</td>
                                <td width="31%" colspan="3" style="border-right:1px solid black;">
                                    <t t-if="o.name">
                                        <span t-field="o.name"/>
                                    </t>
                                </td>
                            </tr>
                            <tr width="100%" style="line-height:25px;border-left:1px solid black;border-right:1px solid black;">
                                <td width="10%" style="vertical-align: top;padding-left:5px">TRN NO.</td>
                                <td width="2%" style="vertical-align: top;text-align:center;padding-left:5px">:</td>
                                <td width="40%" colspan="3" style="">
                                    <span t-if="o.partner_id">
                                        <span t-field="o.partner_id.vat"/>
                                    </span>
                                </td>
                                <td width="15%" style="font-weight: bold;padding-left:5px;">Doc. Date</td>
                                <td width="2%" style="text-align: center;">:</td>
                                <td width="31%" colspan="3" style="border-right:1px solid black;">
                                    <t t-if="o.date_order">
                                        <span t-field="o.date_order" t-options="{'widget': 'date'}"/>
                                    </t>
                                </td>
                            </tr>
                            <tr style="line-height:25px;border-left:1px solid black;border-right:1px solid black;">
                                <td width="10%" style="font-weight: bold; padding-left:5px">Attention</td>
                                <td width="2%" style="text-align: center;">:</td>
                                <td width="40%" colspan="3" style="">
                                    <span t-if="o.attention">
                                        <span t-field="o.attention"/>
                                    </span>
                                </td>       
                                <td width="15%" style="font-weight: bold;padding-left:5px;">Job</td>
                                <td width="2%" style="text-align: center;">:</td>
                                <td width="31%" colspan="3" style="border-right:1px solid black;">
                                    <t t-if="o.order_line">
                                        <t t-if="o.order_line[0].order_id.material_req_id.job_number">
                                            <t t-esc="o.order_line[0].order_id.material_req_id.job_number.name"/>
                                        </t>
                                    </t>
                                </td>
                            </tr>
                            <tr style="line-height:25px;border-left:1px solid black;border-right:1px solid black;">
                                <td width="10%" style="font-weight: bold; padding-left:5px">Email</td>
                                <td width="2%" style="text-align: center;">:</td>
                                <td width="40%" colspan="3" style="">
                                    <span t-if="o.partner_id.email">
                                        <span t-field="o.partner_id.email"/>
                                    </span>
                                </td>
                                <td width="15%" style="font-weight: bold;color: border-right:1px solid black;padding-left:5px ">MR Remarks</td>
                                <td width="2%" style="text-align: center;">:</td>
                                <td width="31%" style="border-right:1px solid black;">
                                    <span t-if="o.mr_remarks">
                                        <span t-field="o.mr_remarks"/>
                                    </span>
                                </td>
                            </tr>

                            <tr style="line-height:25px;border-left:1px solid black;border-right:1px solid black;border-bottom:1px solid black;">
                                <td width="10%" style="font-weight: bold; padding-left:5px">Tel</td>
                                <td width="2%" style="text-align: center;">:</td>
                                <td width="40%" colspan="3" style="">
                                   <span t-if="o.partner_id.phone">
                                        <span t-field="o.partner_id.phone"/>
                                    </span>
                                </td>
                                <td width="15%" style="font-weight: bold;color: border-right:1px solid black;padding-left:5px ">Mobile</td>
                                <td width="2%" style="text-align: center;">:</td>
                                <td width="31%" colspan="3" style="border-right:1px solid black;">
                                <span t-if="o.partner_id.mobile">
                                        <span t-field="o.partner_id.mobile"/>
                                    </span>
                                </td>
                            </tr>
                             
                        </table>

                        <table width="100%" style="width: 100%; ">
                            <tr style="border:1px solid black;font-size: 14px; font-weight: bold;">
                                <td width="2%" style="text-align:center; font-weight: bold;  background-color:#5697D2; color:white; padding-top:10px; padding-bottom:10px; border-right:1px solid black;">
                                    <b>S.No.</b>
                                </td>
                                <td width="13%" style="text-align:center; font-weight: bold; background-color:#5697D2; color:white; padding-top:10px; padding-bottom:10px; border-right:1px solid black;">
                                    <b>MR NO.</b>
                                </td>
                                <td width="13%" style="text-align:center; font-weight: bold; background-color:#5697D2; color:white;padding-top:10px; padding-bottom:10px; border-right:1px solid black;">
                                    <b>Job</b>
                                </td>
                                <td width="30%" style="text-align:center; font-weight: bold; background-color:#5697D2; color:white; padding-top:10px; padding-bottom:10px; border-right:1px solid black;">
                                    <b>Description</b>
                                </td>
                                <td width="10%" style="text-align:center; font-weight: bold; background-color:#5697D2; color:white; padding-top:10px; padding-bottom:10px; border-right:1px solid black;">
                                    <b>Unit</b>
                                </td>
                                <td width="10%" style="text-align:center; font-weight: bold; background-color:#5697D2; color:white; padding-top:10px; padding-bottom:10px; border-right:1px solid black;">
                                    <b>QTY</b>
                                </td>
                                <td width="10%" style="text-align:center; font-weight: bold; background-color:#5697D2; color:white; padding-top:10px; padding-bottom:10px;">
                                    <b>Rate ( <t t-esc="o.currency_id.name"/> )</b>
                                </td>
                                <td width="12%" style="text-align:center; font-weight: bold; background-color:#5697D2; color:white; padding-top:10px; padding-bottom:10px;">
                                    <b>Total ( <t t-esc="o.currency_id.name"/> )</b>
                                </td>
                            </tr>
                            <t t-set="sl_counter" t-value="1"/>
                            <t t-set="subtotal" t-value="0"/>
                            <t t-set="disc" t-value="0.00"/>
                            <t t-foreach="o.order_line" t-as="line">
                                <tr style="font-size: 14px;border-bottom:hidden;border-left:1px solid black;border-right:1px solid black; height: 25px;">
                                    <td style="text-align:center;font-size:12px">
                                        <span t-esc="sl_counter"/>
                                    </td>
                                    <td style="padding-left:5px;border: 1px solid black;font-size:12px">
                                        <t t-if="line.order_id.material_req_id.name">
                                            <t t-esc="line.order_id.material_req_id.name"/>
                                        </t>

                                    </td>
                                    <td style="padding-left:5px;border: 1px solid black;font-size:12px">
                                        <t t-if="line.order_id.material_req_id.job_number">
                                            <t t-esc="line.order_id.material_req_id.job_number.name"/>
                                        </t>
                                    </td>
                                    <td style="padding-left:5px;border: 1px solid black;font-size:12px">
                                        <t t-if="line.product_id">
                                            <t t-esc="line.product_id.name"/>
                                        </t>
                                    </td>
                                    <td style="text-align:center;border: 1px solid black;font-size:12px">
                                        <t t-if="line.product_uom">
                                            <t t-esc="line.product_uom.name"/>
                                        </t>
                                    </td>
                                    <td style="text-align:right;border: 1px solid black;font-size:12px;padding-right:4px;">
                                        <t t-if="line.product_qty">
                                            <t t-esc="line.product_qty"/>
                                        </t>
                                        <t t-set="subtotal" t-value="subtotal+(line.product_qty*line.price_unit)"/>
                                        <t t-if="line.discount_amount">
                                            <t t-set="disc" t-value="disc+line.discount_amount"/>
                                        </t>
                                    </td>
                                    <td style="text-align:right;border: 1px solid black;font-size:12px;padding-right:3px;">
                                        <t t-if="line.price_unit">
                                            <t t-esc="'{:.3f}'.format(line.price_unit)"/>
                                        </t>
                                    </td>
                                    <td style="text-align:right;border: 1px solid black;font-size:12px;padding-right:3px;">
                                        <!-- <t t-if="line.price_subtotal"> -->
                                        <t t-esc="'{:.3f}'.format(line.price_unit * line.product_qty)"/>
                                        <!-- </t> -->
                                    </td>
                                </tr>
                                <t t-set="sl_counter" t-value="sl_counter + 1"/>
                            </t>
                            <t t-set="last_row_style" t-value="'height: %spx; border: 1px solid black; font-size: 14px;' % (380 - (sl_counter * 25))" />
                            <t t-if="(405 - (sl_counter * 25)) > 0">
                                <tr t-att-style="last_row_style">
                                    <td style="text-align: center; border: 1px solid black;" />
                                    <td style="text-align: left; border: 1px solid black;" />
                                    <td style="text-align: right; border: 1px solid black;" />
                                    <td style="text-align: right; border: 1px solid black;" />
                                    <td style="text-align: right; border: 1px solid black;" />
                                    <td style="text-align: right; border: 1px solid black;" />
                                    <td style="text-align: right; border: 1px solid black;" />
                                    <td style="text-align: right; border: 1px solid black;" />
                                </tr>
                            </t>
                            <tr style="border: 1px solid black; font-weight: bold;">
                                <td colspan="4" rowspan="3" style="text-align:left;vertical-align: middle; font-weight: bold; padding-top:10px; padding-bottom:10px; border: 1px solid black;padding-left: 5px;">
                                </td>
                                <td colspan="3" style="font-size:12px;line-height:12px; font-weight: bold; padding-top:5px; padding-bottom:5px; padding-left:5px;padding-right:3px;border-left: 1px solid black;padding-left: 5px;border-bottom: 1px solid black;border-top: 1px solid black;border-right:hidden;">
                                    Sub Total<br/>
                                </td>
                                <td style="border:none;font-weight: bold; padding-top:5px; padding-bottom:5px; padding-left:5px; border: 1px solid black;text-align:right;font-size:12px;padding-right:3px;">
                                     <b>
                                       <t t-esc="'{:.3f}'.format(subtotal)"/>
                                    </b>
                                </td>
                            </tr>
                            <tr>
                                <t t-if="disc &gt; 0">
                                    <td colspan="3" style="font-size:12px;line-height:12px;font-weight: bold; padding-top:5px; padding-bottom:5px; padding-left:5px;padding-right:3px; border-left: 1px solid black;padding-left: 5px;border-bottom: 1px solid black;border-top: 1px solid black;border-right:hidden;">
                                        Discount
                                        <br/>
                                    </td>
                                    <td style="border:none;text-align:right; font-weight: bold; padding-top:5px; padding-bottom:5px; padding-left:5px; border: 1px solid black;padding-right:3px;font-size:12px">
                                        <b>
                                            <t t-esc="'{:.3f}'.format(disc)"/>
                                        </b>
                                    </td>
                                </t>
                            </tr>
                            <tr>
                                <td colspan="3" style="font-size:12px;line-height:12px;font-weight: bold; padding-top:5px; padding-bottom:5px; padding-left:5px; padding-right:3px;border-left: 1px solid black;padding-left: 5px;border-bottom: 1px solid black;border-top: 1px solid black;border-right:hidden;">
                                    Net Amount<br/>
                                </td>
                                <td style="border:none;text-align:right; font-weight: bold; padding-top:5px; padding-bottom:5px; padding-left:5px; border: 1px solid black;padding-right:3px;font-size:12px;padding-right:3px;">
                                    <b>
                                        <t t-esc="'{:.3f}'.format(subtotal-disc)"/>
                                    </b>
                                </td>
                            </tr>
                            <tr style=" border:none;border: 1px solid black; font-weight: bold;">
                                <td colspan="4" rowspan="3" style="text-align:left;vertical-align: middle; font-weight: bold; padding-top:10px; padding-bottom:10px; border: 1px solid black;padding-left: 5px;">
                                    <t t-if="o.currency_id">
                                        <t t-esc="o.currency_id.with_context(lang='en_US').amount_to_text(o.amount_total)+ ' Only'"/>
                                    </t> 
                                </td>
                            </tr>
                            <tr>
                                <td colspan="3" style="font-size:12px;line-height:12px;font-weight: bold; padding-top:5px; padding-bottom:5px; padding-left:5px; padding-right:3px;border-left: 1px solid black;padding-left: 5px;border-bottom: 1px solid black;border-top: 1px solid black;border-right:hidden;">
                                     <t t-if="len(o.order_line)">
                                                <t t-if="o.order_line[0].taxes_id">
                                                    VAT<t t-esc="o.order_line[0].taxes_id[0].name"/>
                                                </t>
                                        </t>
                                </td>
                                <td style="border:none;text-align:right; font-weight: bold; padding-top:5px; padding-bottom:5px; padding-left:5px; border: 1px solid black;padding-right:3px;font-size:12px;padding-right:3px;">
                                    <b>
                                        <t t-if="len(o.order_line)">
                                            <t t-if="o.order_line[0].taxes_id">
                                                <t t-esc="'{:.3f}'.format((subtotal - disc) * 0.05)"/>
                                            </t>
                                            <!--<t t-else="">-->
                                            <!--    0.0-->
                                            <!--</t>-->
                                        </t>
                                    </b>
                                </td>
                            </tr>
                             <tr>
                                <td colspan="3" style="font-size:12px;line-height:12px;font-weight: bold; padding-top:5px; padding-bottom:5px; padding-left:5px; padding-right:3px;border-left: 1px solid black;padding-left: 5px;border-bottom: 1px solid black;border-top: hidden;border-right:hidden;">
                                    Net Total
                                   <span style="padding-left:5px;">( <t t-esc="o.currency_id.name"/> )</span>
                                </td>
                                <td style="border:none;text-align:right; font-weight: bold; padding-top:5px; padding-bottom:5px; padding-left:5px; border: 1px solid black; border-top:hidden;padding-right:3px;font-size:12px;padding-right:3px;">
                                    <b>
                                        <!--<t t-esc="'{:.3f}'.format((subtotal - disc) + round((subtotal - disc) * 0.05, 3))"/>-->
                                        <t t-esc="'{:.3f}'.format(o.amount_total)"/>
                                    </b>

                                </td>
                            </tr>
                        </table>
                        <table width="100%" class="table table-sm table-borderless" style="font-size: 14px;border-collapse: collapse;">
                            <tr width="100%" style="line-height:20px;border-left:1px solid black;border-right:1px solid black;">
                                <td width="20%" style="font-weight: bold;font-size:12px">Payment Terms</td>
                                <td width="2%" style="text-align: center;">:</td>
                                <td width="78%" style="">
                                    <span t-if="o.payment_term_id">
                                        <span t-field="o.payment_term_id.name"/>
                                    </span>
                                </td>
                            </tr>
                            <tr width="100%" style="line-height:20px;border-left:1px solid black;border-right:1px solid black;border-bottom:1px solid black">
                                <td width="20%" style="font-weight: bold;font-size:12px">Delivery Date</td>
                                <td width="2%" style="text-align: center;">:</td>
                                <td width="78%" style="">
                                    <span t-if="o.date_planned">
                                         <span t-field="o.date_planned" t-options="{'widget': 'date'}"/>
                                    </span>
                                </td>
                            </tr>
                        </table>
                        <table style="margin-top:5px;width:100%">
                            <tr>
                                <td style="border:none;text-align:right">
                                    <t t-set="approved_user" t-value="request.env['res.users'].sudo().search([('id', '=', o.approved_by.id)], limit=1)"/>
                                    <span t-if="approved_user.digital_sign" style="height:4cm;width:6cm;">
                                        <img t-att-src="image_data_uri(approved_user.digital_sign)" style="max-height: 4cm;"/>
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <td style="border:none;padding-left:650px">
                                    <b> For Kehlan Pools </b>
                                </td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
            </t>
        </template>
    </data>
</odoo>

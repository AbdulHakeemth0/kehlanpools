<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_stock_quant_tree_editable_inherit_warranty" model="ir.ui.view">
        <field name="name">view.stock.quant.tree.editable.inherit.warranty</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_editable"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='reserved_quantity']" position="after">
                <field name="number_of_warranty" readonly="1"/>
                <field name="warranty_type" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="product_template_only_form_view_inherit_warranty" model="ir.ui.view">
        <field name="name">product.template.only.form.view.inherit.warranty</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='variants']" position="after">
                <page name="product_warranty" string="Warranty">
                    <field name="template_warranty_ids" widget="one2many">
                        <list create="0" delete="0">
                            <field name="partner_id"/>
                            <field name="number_of_warranty"/>
                            <field name="warranty_type"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
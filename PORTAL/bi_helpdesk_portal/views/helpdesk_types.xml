<?xml version="1.0"?>
<odoo>
    <record id="helpdesk_ticket_view_form_inherited_type" model="ir.ui.view">
        <field name='name'>helpdesk.ticket.form.inherit.type</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">
            <!-- <xpath expr="//button[@name='action_convert_ticket_to_lead_or_opportunity']" position="attributes">
                <attribute name="invisible">is_opportunity</attribute>
            </xpath> -->
            <div name="button_box" position="inside">
                <button class="oe_stat_button" type="object" name="action_get_opportunity" icon="fa-list-alt" invisible="lead_count == 0">
                    <field string="Opportunity" name="lead_count" widget="statinfo"/>
                </button>

                <button class="oe_stat_button" type="object" name="action_get_sale_order" icon="fa-list-alt" invisible="order_count == 0">
                    <field string="Sale Order" name="order_count" widget="statinfo"/>
                </button>
            </div>
            <xpath expr="header" position="inside">
                <button class="btn btn-secondary" type="object" string="Assign"
                        name="action_assign" invisible="is_assigned"
                        />
            </xpath>
            <xpath expr="//field[@name='email_cc']" position="after">
                <field name="deadline"/>
                <field name="hours" invisible="deadline == 'date'"/>
                <field name="date" invisible="deadline == 'hours'"/>
                <field name="remarks"/>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="cutomer_m_number"/>
            </xpath>
            <xpath expr="//field[@name='team_id']" position="after">
                <field name="ticket_type" required="1"/>
                <field name="team_lead_id"/>
                <field name="is_opportunity" invisible="1"/>
                <field name="is_assigned" invisible="1"/>
                <field name="mem_ids" widget="many2many_tags" invisible="1"/>
                <field name="members_ids" widget="many2many_tags" options="{'no_create': True, 'no_edit':True}" domain="[('id', 'in', mem_ids)]"/>
                <field name="lead_count" invisible="1"/>
                <field name="order_count" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <!-- <record id="helpdesk_button_hide_view" model="ir.ui.view">
        <field name='name'>helpdesk.ticket.button</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="crm_helpdesk.helpdesk_ticket_view_form_inherited"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_convert_ticket_to_lead_or_opportunity'][2]" position="attributes">
                <attribute name="invisible">is_opportunity or is_assigned</attribute>
            </xpath>
        </field>
    </record> -->


    <record id="helpdesk_ticket_view_tree_inherit_helpdesk_type" model="ir.ui.view">
        <field name='name'>helpdesk.ticket.list.inherit.helpdesk.type</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_tickets_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="ticket_type"/>
                <!-- <field name="deadline" column_invisible="1"/>
                <field name="hours" column_invisible="deadline == 'date'"/>
                <field name="date" column_invisible="deadline == 'hours'"/> -->
            </xpath>
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="team_lead_id"/>
                <field name='create_uid'/>
            </xpath>
            <xpath expr="//field[@name='stage_id']" position="after">
                <field name="remarks"/>
            </xpath>
        </field>
    </record>

    <record id="helpdesk_ticket_view_search_analysis_inherit" model="ir.ui.view">
        <field name="name">helpdesk.ticket.search.inherit</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_search_analysis"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">               
                <field name="cutomer_m_number"/>
            </xpath>
        </field>
    </record>


    <record id="action_helpdesk_type_view" model="ir.actions.act_window">
        <field name="name">Helpdesk Type</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">kanban,list,form,activity</field>
        <field name="view_id" ref="helpdesk.helpdesk_tickets_view_tree"/>
        <field name="search_view_id" ref="helpdesk.helpdesk_tickets_view_search" />
        <!-- <field name="context">{}</field>
        <field name="domain">[()]</field> -->
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Helpdesk Tickets
            </p>
        </field>
    </record>
    <menuitem id="helpdesk_type_menu" 
        name="Helpdesk Types" 
        action="action_helpdesk_type_view" 
        sequence="10" 
        parent="helpdesk.menu_helpdesk_root"/>
  
    <!-- Complaints -->
   <record id="action_complaint_view" model="ir.actions.act_window">
        <field name="name">Complaints</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="helpdesk.helpdesk_tickets_view_tree"/>
        <field name="search_view_id" ref="helpdesk.helpdesk_tickets_view_search" />        
        <field name="domain">[('ticket_type', '=', 'complaint')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Helpdesk Complaints
            </p>
        </field>
    </record>
    <!-- Menu Item Complaint -->
    <menuitem id="complaint_menu"
        name="Complaints"
        parent="helpdesk_type_menu"
        action="action_complaint_view"
        sequence="0"/>

    <!-- Service -->
    <record id="action_service_view" model="ir.actions.act_window">
        <field name="name">Services</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="helpdesk.helpdesk_tickets_view_tree"/>
        <field name="search_view_id" ref="helpdesk.helpdesk_tickets_view_search" />        
        <field name="domain">[('ticket_type', '=', 'service')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Helpdesk Services
            </p>
        </field>
    </record>
    <!-- Menu Item Service -->
    <menuitem id="service_menu"
        name="Services"
        parent="helpdesk_type_menu"
        action="action_service_view"
        sequence="0"/>

    <!-- Maintenance -->
    <record id="action_maintenance_view" model="ir.actions.act_window">
        <field name="name">Maintenances</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="helpdesk.helpdesk_tickets_view_tree"/>
        <field name="search_view_id" ref="helpdesk.helpdesk_tickets_view_search" />        
        <field name="domain">[('ticket_type', '=', 'maintenance')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Helpdesk Maintenances
            </p>
        </field>
    </record>
    <!-- Menu Item Maintenance -->
    <menuitem id="maintenance_menu"
        name="Maintenances"
        parent="helpdesk_type_menu"
        action="action_maintenance_view"
        sequence="0"/>
        
</odoo>

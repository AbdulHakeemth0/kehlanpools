<odoo>

    <record id="sale_order_custom_view_form_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.custom.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="ticket_id" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="sale_order_custom_view_ticket_id_filter" model="ir.ui.view">
        <field name="name">sale.order.form.ticket_id.custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">               
                <field name="ticket_id"/>
            </xpath>
        </field>
    </record>

</odoo>
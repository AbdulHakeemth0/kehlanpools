<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Form view of employee_team model-->
    <record id='employee_team_view_form' model='ir.ui.view'>
        <field name="name">employee.team.view.form</field>
        <field name="model">hr.employee.team</field>
        <field name="arch" type="xml">
            <form string="Team">
                <sheet>
                <div class="oe_title">
                        <label for="name" string="Team"/>
                        <h1>
                            <field class="text-break" name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group name="left" string="Team Details">
                            <field name="team_lead_id" widget="many2one_avatar_user"/>
                            <field name="members_ids" widget="many2many_avatar_user"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <!--list view of employee_team model-->
    <record id='employee_team_view_list' model='ir.ui.view'>
        <field name="name">employee.team.view.list</field>
        <field name="model">hr.employee.team</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>
    <!--Menu action for employee_checklist model-->
    <record id="employee_team_action" model="ir.actions.act_window">
        <field name="name">Team Details</field>
        <field name="res_model">hr.employee.team</field>
        <field name="view_mode">list,form</field>
    </record>
    <!--Menu for the model employee_checklist-->
    <menuitem
            id="employee_team_menu"
            action="employee_team_action"
            parent="hr.menu_human_resources_configuration"
            sequence="4"
            />
</odoo>

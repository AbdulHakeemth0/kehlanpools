<?xml version="1.0"?>
<odoo>
    <data>
        <record id="view_hr_employee_form_inherited_view" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.view1</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='work_email']" position="before">
                    <field name="is_team_lead"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
<odoo>
    <!-- Inherit the hr.attendance form view -->
    <record id="view_hr_attendance_form" model="ir.ui.view">
        <field name="name">hr.attendance.form</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//group" position="inside">
                <group>
                    <field name="team_member_ids" widget="many2many_tags" options="{'no_create': True}" placeholder="Select team members"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_hr_attendance_tree" model="ir.ui.view">
        <field name="name">hr.attendance.tree</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.view_attendance_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list//field[@name='employee_id']" position="after">
                <field name="team_member_ids"/>
            </xpath>
        </field>
    </record>
</odoo>
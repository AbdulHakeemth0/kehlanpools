<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_mep_equipment_form" model="ir.ui.view">
        <field name="name">mep.equipment.form</field>
        <field name="model">mep.equipment</field>
        <field name="arch" type="xml">
            <form string="MEP Equipments">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_mep_equipment_list" model="ir.ui.view">
        <field name="name">mep.equipment.list</field>
        <field name="model">mep.equipment</field>
        <field name="arch" type="xml">
            <list string="MEP Equipments">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_mep_equipment" model="ir.actions.act_window">
        <field name="name">MEP Equipment</field>
        <field name="res_model">mep.equipment</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create New MEP Equipment
            </p>
        </field>
    </record>

    <menuitem
        id="menu_mep_equipment"
        name="MEP Equipments"
        parent="crm.crm_menu_config"
        action="action_mep_equipment"
        sequence="10"/>

</odoo>

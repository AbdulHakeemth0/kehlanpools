<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="custom_sale_order_document_demo1" inherit_id="bi_amc_proposal.report_amc">
        <xpath expr="//h3[hasclass('text-center')]" position="after">
        <t t-if="o.state in ('draft','submitted')">
            <div class="row" t-if="report_type == 'pdf'">
                <div name="watermark">
                    <span style="-webkit-transform:rotate(-45deg); transform:rotate(-45deg); color:coral; font-size:8em;position:absolute; opacity:0.2;padding-left:300px;text-align: center;padding-top:100px">
                        DRAFT
                    </span>
                </div>
            </div>
        </t>
        </xpath>
    </template>

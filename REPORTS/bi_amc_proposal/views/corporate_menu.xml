<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <menuitem id="menu_corporate_template_details"
                  name="AMC Corporate"
                  parent="bi_amc_proposal.menu_template_details"
                  sequence="3"/>

        <menuitem id="menu_non_corporate_template_details"
                  name="AMC Non-Corporate"
                  parent="bi_amc_proposal.menu_template_details"
                  sequence="4"/>

        <record id="view_tree_corporate_template_details" model="ir.ui.view">
            <field name="name">corporate.template.details.list</field>
            <field name="model">corporate.template.details</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="view_form_corporate_template_details" model="ir.ui.view">
            <field name="name">corporate.template.details.form</field>
            <field name="model">corporate.template.details</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>

                        <notebook>
                        <page string="Corporate Template Details" name="corporate">
                                <field name="template_line_ids" widget="section_and_note_one2many">
                                    <list editable="bottom">
                                        <control>
                                            <create name="add_line_control" string="Add a line"/>
                                            <create name="add_section_control" string="Add a section"
                                                    context="{'default_display_type': 'line_section'}"/>

                                        </control>
                                        <field name="sl_no" groups="base.group_no_one"/>
                                        <field name="name"/>
                                        <field name="asset_action" store="True"/>
                                        <field name="display_type" column_invisible="True"/>
                                    </list>
                                </field>
                        </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tree_payment_term_details" model="ir.ui.view">
            <field name="name">payment.term.details.list</field>
            <field name="model">payment.term.details</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="name"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_form_payment_term_details" model="ir.ui.view">
            <field name="name">payment.term.details.form</field>
            <field name="model">payment.term.details</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                        <notebook>
                            <page string="Payment Term Details" name="payment_term" invisible="1">
                                <field name="payment_line_ids" widget="section_and_note_one2many">
                                    <list editable="bottom">
                                        <field name="first_payment_percentage"/>
                                        <field name="second_payment_percentage"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>


<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="account_move_view_search_report" model="ir.ui.view">
            <field name="name">account.move.view.report</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="action_voucher_report" type="object" string="Voucher Report" class="btn-primary" invisible="state not in ['posted']"/>
                </xpath>
                <xpath expr='//field[@name="journal_id"]' position='after'>
                    <field name="is_voucher" invisible="1"/>
                </xpath>
                <xpath expr="//page[@name='other_info']" position="after">
                    <page id="approval_tab" string="Approvals" name="approval_info">
                        <group>
                            <field name="prepared_by"/>
                            <field name="approval1"/>
                            <field name="approval1_name" invisible="not approval1"/>
                        </group>
                        <group>
                            <field name="approval2"/>
                            <field name="approval2_name" invisible="not approval2"/>
                            <field name="received_by"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
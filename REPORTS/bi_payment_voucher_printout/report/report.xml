<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="payment_voucher_paperformat" model="report.paperformat">
                <field name="name">Payment Voucher</field>
                <field name="default" eval="True" />
                <field name="format">A4</field>
                <field name="orientation">Portrait</field>
                <field name="page_height">0</field>
                <field name="page_width">0</field>
                <field name="margin_top">27</field>
                <field name="margin_bottom">20</field>
                <field name="margin_left">5</field>
                <field name="margin_right">5</field>
                <field name="header_line" eval="False"/>
                <field name="header_spacing">27</field>
                <field name="dpi">90</field>
        </record>


        <record id="payment_voucher_report_pdf" model="ir.actions.report">
                <field name="name">Payment Voucher</field>
                <field name="model">account.move</field>
                <field name="report_type">qweb-pdf</field>
                <field name="report_name">bi_payment_voucher_printout.report_payment_voucher_template</field>
                <field name="report_file">bi_payment_voucher_printout.report_payment_voucher_template</field>
                <!-- <field name="binding_model_id" ref="account.model_account_move"/> -->
                <field name="binding_type">report</field>
                <field name="paperformat_id" ref="bi_payment_voucher_printout.payment_voucher_paperformat"/>
        </record>
</odoo>

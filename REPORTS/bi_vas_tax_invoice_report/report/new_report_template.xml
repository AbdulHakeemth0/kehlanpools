<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="report_tax_invoice_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <t t-call="bi_vas_tax_invoice_report.vas_invoice_header"/>
                    <div class="page">
                        <table class="table" style="width:100%;border-top:none;border-bottom:none; margin-top:-15px; ">
                            <tr style="border-top:hidden; height:10px;">
                                <td colspan="6" style="text-align: center; font-size: 18px; font-weight: bold;border:1px solid black; ">
                                    TAX INVOICE
                                    <br />
                                    <span style="font-size: 12px;font-weight: bold;">TRN:</span>
                                    <span t-if="o.company_id">
                                        <span t-field="o.company_id.vat" style="font-size: 14px;font-weight: bold;"/>
                                    </span>
                                </td>
                            </tr>
                            <tr style="border:1px solid black;line-height: 10px;">
                                <td style="border:1px solid black;">
                                    <strong>
                                        <span t-if="o.company_id">
                                            <span t-field="o.company_id.name" style="font-size: 14px;" />
                                        </span>
                                    </strong>
                                </td>
                                <td style="width: 20%; vertical-align:top; border:1px solid black;">Invoice No.</td>
                                <td colspan="4" style="width: 20%; vertical-align:top; border:1px solid black;">Dated:</td>
                            </tr>
                            <tr style="border:1px solid black;">
                                <td rowspan="3" style="width: 33%;line-height:23px;vertical-align:top; border:1px solid black;">
                                     <t t-if="o.company_id.company_registry">C.R.No: -
                                        <span t-field="o.company_id.company_registry"/>
                                    </t><br/>
                                    <t t-if="o.company_id.zip">PO Box -
                                        <span t-field="o.company_id.zip"/>
                                    </t>,
                                    <br/>
                                    <span t-if="o.company_id.street" t-field="o.company_id.street"/>,
                                    <span t-if="o.company_id.city" t-field="o.company_id.city"/>, Sultanate of
                                    <span t-if="o.company_id.country_id" t-field="o.company_id.country_id.name"/>
                                    <br/>
                                    <t t-if="o.company_id.email">E-Mail:
                                        <span t-field="o.company_id.email"/>
                                    </t>
                                    <br/>
                                    <span t-if="o.company_id.website" style="color:#0096FF; text-decoration:underline;">
                                        <span t-field="o.company_id.website"/>
                                    </span>
                                </td>
                                <td style="width: 33%; vertical-align:top; border:1px solid black;line-height: 10px;">
                                    <b>
                                        <span t-if="o.name">
                                            <span t-field="o.name"/>
                                        </span>
                                    </b>
                                </td>
                                <td colspan="4" style="width: 33%; vertical-align:top; text-align:left; border:1px solid black;line-height: 10px;">
                                    <b>
                                        <span t-if="o.invoice_date">
                                            <span t-field="o.invoice_date" t-options='{"format": "dd/MM/yyyy"}'/>
                                        </span>
                                    </b>
                                </td>
                            </tr>
                            <tr style="border: 1px solid black;">
                                <td style="width: 33%;height:25px; vertical-align: top; text-align: left; border: 1px solid black;">
                                    Delivery Note
                                    <br/>
                                    <span t-if="o.delivery_note">
                                        <b><span t-field="o.delivery_note" /> </b>
                                    </span>
                                </td>
                                <td colspan="4" style="width: 33%;height:25px;vertical-align:top; border: 1px solid black;">Mode/Terms of Payment
                                    <br/>
                                    <span t-if="o.terms_of_pay">
                                        <b><span t-field="o.terms_of_pay"/> </b>
                                    </span>
                                </td>
                            </tr>
                            <tr style="border: 1px solid black;">
                                <td style="width: 33%; height:25px;vertical-align: top; text-align: left; border: 1px solid black;">
                                    Qtn's Ref
                                    <br/>
                                    <span t-if="o.invoice_line_ids[0].sale_line_ids.order_id.name">
                                        <b>
                                            <span t-field="o.invoice_line_ids[0].sale_line_ids.order_id.name"/>
                                        </b>
                                    </span>
                                </td>
                                <td colspan="4" style="width: 33%;height:25px;vertical-align:top; border: 1px solid black;">Other Reference(s)
                                    <br/>
                                    <span t-if="o.other_ref">
                                        <b>
                                            <span t-field="o.other_ref"/>
                                        </b>
                                    </span>
                                </td>
                            </tr>
                            <tr style="border:1px solid black;line-height: 25px;">
                                <td rowspan="3"
                                    style="width: 33%; vertical-align: top; text-align: left; border: 1px solid black;">
                                    <b>Customer Name:</b>
                                    <br/>
                                    <t t-if="o.partner_id">
                                        <b>
                                            <span t-field="o.partner_id.name"/><br/>
                                            <t t-if="o.partner_id.street2">
                                                <span t-esc="o.partner_id.street2"/>,
                                            </t>
                                            <t t-if="o.partner_id.city">
                                                <span t-esc="o.partner_id.city"/>,<br/>
                                            </t>
                                            <t t-if="o.partner_id.country_id">
                                                <t t-if="o.partner_id.country_id.code == 'OM'">
                                                    Sultanate of <span t-esc="o.partner_id.country_id.name"/><br/>
                                                </t>
                                                <t t-else="">
                                                    <span t-esc="o.partner_id.country_id.name"/><br/>
                                                </t>
                                            </t>
                                            <t t-if="o.partner_id.vat">
                                                <span t-esc="o.partner_id.vat"/>
                                            </t>
                                        </b>
                                    </t>
                                </td>
                                <td colspan="4" style="width: 66%; height:25px;vertical-align: top; text-align: left; border: 1px solid black;">
                                    Buyer's Order No:
                                    <!-- <br/> -->
                                    <span t-if="o.buyers_order_no">
                                        <b>
                                            <span t-field="o.buyers_order_no"/>
                                        </b>
                                    </span>
                                </td>
                                <!-- <td colspan="4" style="width: 33%;height:25px; vertical-align: top; text-align: left; border: 1px solid black;">
                                    Dated:
                                    <br/>
                                    <span t-if="o.invoice_date">
                                        <b>
                                            <span t-field="o.invoice_date"/>
                                        </b>
                                    </span>
                                </td> -->
                            </tr>
                            <tr style="border: 1px solid black;line-height: 25px;">
                                <td style="width: 33%;height:25px; vertical-align: top; text-align: left; border: 1px solid black;">
                                    Despatched through:
                                    <br/>
                                    <span t-if="o.desp_through">
                                        <b>
                                            <span t-field="o.desp_through"/>
                                        </b>
                                    </span>
                                </td>
                                <td colspan="4" style="width: 33%;height:25px; border: 1px solid black;">Destination:
                                <br/>
                                    <span t-if="o.dest">
                                        <b>
                                            <span t-field="o.dest"/>
                                        </b>
                                    </span></td>
                            </tr>
                            <tr style="border: 1px solid black;border-bottom:none;line-height: 10px;">
                                <td style="width: 33%; vertical-align: top; text-align: left; border: 1px solid black;">
                                    Terms of Delivery
                                </td>
                                <td colspan="4" style="width: 33%; border: 1px solid black;">
                                    <span t-if="o.terms_of_del">
                                        <b>
                                            <span t-field="o.terms_of_del"/>
                                        </b>
                                    </span></td>
                            </tr>
                        </table>
                        <table width="100%" style="border-collapse:collapse;margin-top:-16px;">
                            <tr width="100%" style="border: 1px solid black;border-top:hidden;">
                                <td width="5%" style=" width:50px;vertical-align: top; text-align: center; border: 1px solid black;">
                                    <b>Sl No</b><br/>
                                </td>
                                <td width="54%" style=" vertical-align: top; text-align: center; border: 1px solid black;">
                                    <b>Description</b>
                                </td>
                                <td width="7%" style="vertical-align: top; text-align: center; border: 1px solid black;">
                                    <b>QTY</b>
                                </td>
                                <td width="9%" style=" vertical-align: top; text-align: center; border: 1px solid black;">
                                    <b>Unit</b>
                                </td>
                                <td width="10%" style=" vertical-align: top; text-align: center; border: 1px solid black;">
                                    <b>Unit Price</b>
                                </td>
                                <td width="15%" style=" vertical-align: top; text-align: center; border: 1px solid black;">
                                    <b>Amount</b>
                                </td>
                            </tr>
                            <t t-set="sl_counter" t-value="1"/>
                            <t t-set="after_discount" t-value="0"/>
                            <t t-set="taxable_amount" t-value="0"/>
                            <t t-set="discount_amount" t-value="sum(o.invoice_line_ids.sale_line_ids.order_id.order_line.filtered(lambda l:l.product_id.is_discount_product).mapped('price_subtotal'))"/>
                            <t t-if="not discount_amount">
                                <t t-set="discount_amount" t-value="sum(o.invoice_line_ids.sale_line_ids.filtered(lambda l:l.product_id.is_discount_product).mapped('price_subtotal'))"/>
                            </t>
                            <t t-set="tax_value" t-value="0"/>
                            <t t-foreach="o.invoice_line_ids.filtered(lambda l: not l.product_id.is_discount_product)" t-as="line">
                                <t t-if="line.is_downpayment == False and line.display_type not in ('line_note','line_section')">
                                    <tr width="100%" style="border-top: 1px solid black;border-left: 1px solid black;border-right: 1px solid black;border-bottom: hidden;">
                                        <td width="5%" style="vertical-align: top; text-align: center;border-bottom: hidden;border-left: 1px solid black;border-right: 1px solid black; ">
                                            <b>
                                                <span t-esc="sl_counter"/>
                                            </b>

                                        </td>
                                        <td width="54%" style="vertical-align: top; border-bottom: hidden; text-align: left;border-left: 1px solid black;border-right: 1px solid black;padding-left:4px;">
                                            <span t-if="line.product_id">
                                                <b>
                                                    <span t-field="line.product_id.name"/>
                                                </b>
                                            </span>
                                        </td>
                                        <td width="7%" style="vertical-align: top; border-bottom: hidden; text-align:right;border-left: 1px solid black;border-right: 1px solid black;padding-left:4px;">
                                            <span t-if="line.quantity">
                                                <b>
                                                    <span t-esc="'{:.3f}'.format(line.quantity)"/>
                                                </b>
                                            </span>
                                        </td>
                                        <td width="9%" style="vertical-align: top; border-bottom: hidden; text-align: center;border-left: 1px solid black;border-right: 1px solid black;padding-left:4px;">
                                            <span t-if="line.product_uom_id">
                                                <b>
                                                    <span t-field="line.product_uom_id.name"/>
                                                </b>
                                            </span>
                                        </td>
                                        <td width="10%" style="text-align:right;vertical-align: top; border-bottom: hidden;border-left: 1px solid black;border-right: 1px solid black;padding-left:4px;">
                                            <span t-if="line.price_unit">
                                                <b>
                                                    <span t-esc="'{:.3f}'.format(line.price_unit)"/>
                                                </b>
                                            </span>
                                        </td>
                                        <td width="15%" style="vertical-align: top; text-align: right;border-bottom: hidden;  border-left: 1px solid black;border-right: 1px solid black;padding-right:4px; ">
                                            <span t-if="line.price_subtotal">
                                                <b>
                                                    <span t-esc="'{:.3f}'.format((line.price_unit)*(line.quantity))"/>
                                                </b>
                                            </span>
                                        </td>
                                    </tr>
                                    <t t-set="sl_counter" t-value="sl_counter + 1"/>
                                </t>
                                <t t-if="line.is_downpayment == True and len(o.invoice_line_ids) >= 1">
                                    <t t-foreach="o.invoice_line_ids.sale_line_ids.order_id.order_line.filtered(lambda l: not l.product_id.is_discount_product)" t-as="orderline">
                                        <t t-if="orderline.is_downpayment == False and orderline.display_type not in ('line_note','line_section')">
                                            <tr width="100%" style="border-top: 1px solid black;border-left: 1px solid black;border-right: 1px solid black;border-bottom: hidden;">
                                                <td width="5%" style="vertical-align: top; text-align: center;border-bottom: hidden;border-left: 1px solid black;border-right: 1px solid black; ">
                                                    <b>
                                                        <span t-esc="sl_counter"/>
                                                    </b>

                                                </td>
                                                <td width="54%" style="vertical-align: top; border-bottom: hidden; text-align: left;border-left: 1px solid black;border-right: 1px solid black;padding-left:4px;">
                                                    <span t-if="orderline.product_id">
                                                        <b>
                                                            <span t-field="orderline.product_id.name"/>
                                                        </b>
                                                    </span>
                                                </td>
                                                <td width="7%" style="vertical-align: top; border-bottom: hidden; text-align:right;border-left: 1px solid black;border-right: 1px solid black;padding-left:4px;">
                                                    <span t-if="orderline.product_uom_qty">
                                                        <b>
                                                            <span t-esc="'{:.3f}'.format(orderline.product_uom_qty)"/>
                                                        </b>
                                                    </span>
                                                </td>
                                                <td width="9%" style="vertical-align: top; border-bottom: hidden; text-align: center;border-left: 1px solid black;border-right: 1px solid black;padding-left:4px;">
                                                    <span t-if="orderline.product_uom">
                                                        <b>
                                                            <span t-field="orderline.product_uom.name"/>
                                                        </b>
                                                    </span>
                                                </td>
                                                <td width="10%" style="text-align:right;vertical-align: top; border-bottom: hidden;border-left: 1px solid black;border-right: 1px solid black;padding-left:4px;">
                                                    <span t-if="orderline.price_unit">
                                                        <b>
                                                            <span t-esc="'{:.3f}'.format(orderline.price_unit)"/>
                                                        </b>
                                                    </span>
                                                </td>
                                                <td width="15%" style="vertical-align: top; text-align: right;border-bottom: hidden;  border-left: 1px solid black;border-right: 1px solid black;padding-right:4px; ">
                                                    <span t-if="orderline.price_subtotal">
                                                        <b>
                                                            <span t-esc="'{:.3f}'.format((orderline.price_unit)*(orderline.product_uom_qty))"/>
                                                        </b>
                                                    </span>
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-set="sl_counter" t-value="sl_counter + 1"/>
                                    </t>
                                </t>
                            </t>

                            <tr style="border-bottom: 1px solid black;border-top: 1px solid white;border-left: 1px solid black;border-right: 1px solid black;">
                                <t t-if="o.amount_discount">
                                    <td rowspan="7" style="border-left: 1px solid black;border-right: 1px solid black;border-top: 1px solid white;"></td>
                                </t>
                                <t t-else="">
                                    <td rowspan="5" style="border-left: 1px solid black;border-right: 1px solid black;border-top: 1px solid white;"></td>
                                </t>
                                <td style="padding-top:120px;vertical-align: top; text-align: left; border-left: 1px solid black;border-right: 1px solid black;padding-left:5px;border-top: 1px solid white;">
                                    <h6 style="margin-top:3px;text-decoration:underline;">
                                        Bank Details:
                                    </h6>
                                    <t t-if="o.company_id.bank_ids">
                                        <t t-foreach="o.company_id.bank_ids" t-as="bank">
                                            <p>
                                                <t t-if="bank.bank_id.name">
                                                    <t t-esc="bank.bank_id.name"/>
                                                    <br/>
                                                </t>
                                                <t t-if="bank.partner_id.name">
                                                    <t t-esc="bank.partner_id.name"/>
                                                    <br/>
                                                </t>
                                                <t t-if="bank.acc_number">
                                                    <t t-esc="bank.acc_number"/>
                                                    <br/>
                                                </t>
                                                 <t t-if="bank.bank_id.swift_code">
                                                    Swift Code-<t t-esc="bank.bank_id.swift_code"/>
                                                    <br/>
                                                </t>
                                                <t t-if="bank.bank_id.bank_iban_no">
                                                    IBAN No. <t t-esc="bank.bank_id.bank_iban_no"/>
                                                    <br/>
                                                </t>
                                                <t t-if="bank.bank_id.street">
                                                    <t t-esc="bank.bank_id.street"/>,
                                                    <br/>
                                                </t>
                                                <t t-if="bank.bank_id.city">
                                                    <t t-esc="bank.bank_id.city"/>
                                                </t>
                                                <t t-if="bank.bank_id.city and bank.bank_id.country">,</t>
                                                <t t-if="bank.bank_id.country.name">
                                                    <t t-esc="bank.bank_id.country.name"/>
                                                </t>
                                            </p>
                                        </t>
                                    </t>
                                </td>
                                <t t-if="o.amount_discount">
                                    <td rowspan="7" style="border: 1px solid black;"></td>
                                    <td rowspan="7" style="border: 1px solid black;"></td>
                                    <td rowspan="7" style="border: 1px solid black;"></td>
                                </t>
                                <t t-else="">
                                    <td rowspan="5" style="border: 1px solid black;"></td>
                                    <td rowspan="5" style="border: 1px solid black;"></td>
                                    <td rowspan="5" style="border: 1px solid black;"></td>
                                </t>
                                <td style="border: 1px solid black;"></td>
                            </tr>
                            <tr style="border: 1px solid black;">
                                <td style="padding-right:5px;border: 1px solid black; text-align:right;border-top: hidden;border-bottom: hidden;">
                                    <b>Total Amount</b>
                                </td>
                                <td style="padding-right:4px;border: 1px solid black; text-align:right;border-bottom: hidden;">
                                    <b>
                                        <t t-if="len(o.invoice_line_ids) != 1">
                                            <span t-esc="'{:.3f}'.format(sum((line.price_unit)*(line.product_uom_qty) for line in o.invoice_line_ids.sale_line_ids.order_id.order_line.filtered(lambda l: not l.product_id.is_discount_product and 'Down Payment' not in l.name)))"/>
                                            <t t-set="taxable_amount" t-value="sum((line.price_unit)*(line.product_uom_qty) for line in o.invoice_line_ids.sale_line_ids.order_id.order_line.filtered(lambda l: not l.product_id.is_discount_product and 'Down Payment' not in l.name))"/>
                                        </t>
                                    </b>
                                    <b>
                                        <t t-if="len(o.invoice_line_ids) == 1">
                                            <t t-set="amt_sum" t-value="0"/>
                                            <t t-foreach="o.invoice_line_ids.sale_line_ids.order_id.order_line.filtered(lambda l: not l.product_id.is_discount_product and 'Down Payment' not in l.name)" t-as="line">
                                                <t t-set="sum_amt" t-value="0"/>
                                                <t t-if="line.is_downpayment">
                                                    <t t-foreach="line.sale_line_ids.order_id.order_line.filtered(lambda l: not l.product_id.is_discount_product and 'Down Payment' not in l.name)" t-as="orderline">
                                                        <t t-if="orderline.is_downpayment == False">
                                                            <t t-set="sum_amt" t-value="sum_amt + (orderline.price_unit)*(orderline.product_uom_qty)"/>
                                                            
                                                        </t>
                                                    </t>
                                                    <span t-esc="'{:.3f}'.format(sum_amt)"/>
                                                </t>
                                                <t t-else="not line.is_downpayment">
                                                    <t t-set="amt_sum" t-value="amt_sum + (line.price_unit)*(line.product_uom_qty)"/>
                                                </t>
                                            </t>
                                            <t t-if="amt_sum != 0">
                                                <span t-esc="'{:.3f}'.format(amt_sum)"/>
                                                <t t-set="taxable_amount" t-value="amt_sum"/>
                                            </t>
                                        </t>
                                    </b>
                                </td>
                            </tr>
                            
                            <t t-if="o.amount_discount">
                                <tr style="border: 1px solid black;">
                                    <td style="padding-right:5px;border: 1px solid black;border-bottom:hidden; text-align:right;">
                                        <b>Discount Amount</b>
                                    </td>
                                    <td style="padding-right:4px;border: 1px solid black;border-bottom:hidden; text-align:right;">
                                        <b>
                                            <t t-if="o.amount_discount">
                                                <span t-esc="'{:.3f}'.format(o.amount_discount-discount_amount)"/>
                                                <t t-set="discount_amount_value" t-value="o.amount_discount-discount_amount"/>
                                            </t>
                                        </b>
                                    </td>
                                </tr>
                                <tr style="border: 1px solid black;">
                                    <td style="padding-right:5px;border: 1px solid black;border-bottom:hidden; text-align:right;">
                                        <b>Taxable Amount</b>
                                    </td>
                                    <td style="padding-right:4px;border: 1px solid black;border-bottom:hidden; text-align:right;">
                                        <b>
                                            <t t-if="o.amount_untaxed">
                                                <span t-esc="'{:.3f}'.format(sum((line.price_unit)*(line.product_uom_qty) for line in o.invoice_line_ids.sale_line_ids.order_id.order_line.filtered(lambda l: not l.product_id.is_discount_product and 'Down Payment' not in l.name))-(o.amount_discount-discount_amount))"/>
                                                <t t-set="after_discount" t-value="sum((line.price_unit)*(line.product_uom_qty) for line in o.invoice_line_ids.sale_line_ids.order_id.order_line.filtered(lambda l: not l.product_id.is_discount_product and 'Down Payment' not in l.name))-(o.amount_discount-discount_amount)"/>
                                            </t>
                                        </b>
                                    </td>
                                </tr>
                            </t>
                            <tr style="border: 1px solid black;">
                                <td style="padding-right:5px;border: 1px solid black; text-align:right;border-bottom: hidden;">
                                    <t t-if="line._name == 'account.move.line'">
                                        Vat
                                        <b><span t-esc="line.tax_ids and line.tax_ids[0].name or 'Tax'"/></b>
                                    </t>
                                    <t t-if="line._name == 'sale.order.line'">
                                        Vat
                                        <b><span t-esc="line.tax_id and line.tax_id[0].name or 'Tax'"/></b>
                                    </t>
                                </td>
                                <td style="padding-right:4px;border: 1px solid black; text-align:right;border-bottom: 1px solid black;">
                                    <b>
                                       <t t-if="len(o.invoice_line_ids) != 1">
                                            <t t-if="o.amount_tax">
                                                <span t-esc="'{:.3f}'.format((o.amount_tax))"/>
                                                <t t-set="tax_value" t-value="o.amount_tax"/>
                                            </t>
                                            <t t-else="">
                                                <span t-esc="'{:.3f}'.format(sum(
                                                    (line.price_subtotal * (line.tax_ids[0].amount if line.tax_ids else 0) / 100) 
                                                    for line in o.invoice_line_ids
                                                ))"/>
                                                <t t-set="tax_value" t-value="'{:.3f}'.format(sum(
                                                    (line.price_subtotal * (line.tax_ids[0].amount if line.tax_ids else 0) / 100) 
                                                    for line in o.invoice_line_ids
                                                ))"/>
                                            </t>
                                        </t>

                                    </b>
                                    <b>
                                        <t t-if="len(o.invoice_line_ids) == 1">

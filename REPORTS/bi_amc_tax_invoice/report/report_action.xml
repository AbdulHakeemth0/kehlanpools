<odoo>
    <record id="tax_invoice_report_action" model="ir.actions.report">
        <field name="name">AMC Tax Invoice Report</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bi_amc_tax_invoice.tax_invoice_print_template</field>
        <field name="report_file">bi_amc_tax_invoice.tax_invoice_print_template</field>
        <field name="binding_type">report</field>
        <field name="print_report_name">'AMC Tax Invoice - %s' % (object.invoice_line_ids.sale_line_ids.order_id.m_number)</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="paperformat_id" ref="bi_amc_tax_invoice.tax_inovice_paperformat"/>
    </record>
</odoo>
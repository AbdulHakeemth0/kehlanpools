                                </td>
                                <td width="10%" style="text-align:center; font-weight: bold; background-color:#1b497f; color:white; padding-top:10px; padding-bottom:10px; border-right:1px solid black;">
                                    <b>Taxable Amount</b>
                                    <br/>
                                    للضريبة الخاضع المبلغ
                                </td>
                                <td width="10%" style="text-align:center; font-weight: bold; background-color:#1b497f; color:white; padding-top:10px; padding-bottom:10px; border-right:1px solid black;">
                                    <b>(5%)Tax Amount</b>
                                    <br/>
                                    (5%)الضريبة مبلغ
                                </td>
                                <td width="10%" style="text-align:center; font-weight: bold; background-color:#1b497f; color:white; padding-top:10px; padding-bottom:10px;">
                                    <b>Total Amount</b>
                                    <br/>
                                    الكلي لجمالى
                                </td>
                            </tr>
                            <t t-set="sl_counter" t-value="1"/>
                            <t t-foreach="o.invoice_line_ids" t-as="line">
                                <tr style="font-size: 14px;border-bottom:hidden;border-left:1px solid black;border-right:1px solid black;">
                                    <td style="text-align:center;">
                                        <span t-esc="sl_counter"/>
                                    </td>
                                    <td style="text-align:left;border: 1px solid black;">
                                            <span t-if="line.product_label">
                                                <span t-esc="line.product_id.name"/>
                                                <span t-field="line.product_label"/>
                                            </span>
                                    </td>
                                    <td style="text-align:right;border: 1px solid black;">
                                        <span t-if="line.quantity">
                                            <span t-esc="'{:.3f}'.format(line.quantity)"/>
                                        </span>
                                    </td>
                                    <td style="text-align:right;border: 1px solid black;">
                                        <span t-if="line.price_unit">
                                            <span t-esc="'{:.3f}'.format(line.price_unit)"/>
                                        </span>
                                    </td>
                                    <td style="text-align:right;border: 1px solid black;">
                                        <span t-if="line.price_unit">
                                            <span t-esc="'{:.3f}'.format(line.price_unit * line.quantity)"/>
                                        </span>
                                    </td>
                                    <td style="text-align:right;border: 1px solid black;">
                                        <span t-if="line.price_subtotal">
                                            <span t-esc="'{:.3f}'.format(line.price_subtotal * 5 / 100)"/>
                                        </span>
                                    </td>
                                    <td style="text-align:right;border: 1px solid black;">
                                        <span t-if="line.price_subtotal">
                                            <!--<span t-esc="'{:.3f}'.format(line.price_unit + (line.price_unit * 5 / 100))"/>-->
                                            <span t-esc="'{:.3f}'.format(line.price_subtotal + (line.price_subtotal * 5 / 100))"/>
                                        </span>
                                    </td>
                                </tr>
                                <t t-set="sl_counter" t-value="sl_counter + 1"/>
                            </t>

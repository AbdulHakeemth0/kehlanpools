                                <td style="text-align:left; border: 1px solid black;padding-top:5px; padding-bottom:5px;"/>
                                <td style="text-align:right;border: 1px solid black; padding-top:5px; padding-bottom:5px;"/>
                                <td style="text-align:right; border: 1px solid black;padding-top:5px; padding-bottom:5px;"/>
                                <td style="text-align:right; border: 1px solid black;padding-top:5px; padding-bottom:5px;"/>
                                <td style="text-align:right;border: 1px solid black; padding-top:5px; padding-bottom:5px;"/>
                                <td style="text-align:right;border: 1px solid black; padding-top:5px; padding-bottom:5px;"/>
                            </tr>
                            <tr style=" border:none;border: 1px solid black; font-weight: bold;">
                                <td colspan="4" rowspan="3" style="text-align:left;vertical-align: middle; font-weight: bold; padding-top:10px; padding-bottom:10px; border: 1px solid black;padding-left: 5px;">
                                    In Words : <span t-esc="o.currency_id.amount_to_text(sum(line.price_subtotal * 1.05 for line in o.invoice_line_ids))+ ' Only'"/><br/>
                                    <span style="padding-left:90px;" t-esc="o.amount_to_text_bi(sum(line.price_subtotal * 1.05 for line in o.invoice_line_ids))"/>
                                </td>
                                <td colspan="2" style="line-height:14px;border:none;text-align:right; font-weight: bold; padding-top:10px; padding-bottom:10px; border: 1px solid black;padding-right:3px;">
                                    Gross Amount<br/>لمجموع الكليا
                                </td>

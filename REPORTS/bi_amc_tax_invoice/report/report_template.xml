                        <table width="100%" style="width: 100%;">
                            <tr style="border:1px solid black;font-size: 14px; font-weight: bold;">
                                <td width="2%" style="text-align:center; font-weight: bold;  background-color:#1b497f; color:white; padding-top:10px; padding-bottom:10px; border-right:1px solid black;">
                                    <b>Sr.No.</b>
                                    <br/>
                                    م.
                                </td>
                                <td width="28%" style="text-align:center; font-weight: bold; background-color:#1b497f; color:white; padding-top:10px; padding-bottom:10px; border-right:1px solid black;">
                                    <b>Description</b>
                                    <br/>
                                    التفاصيل
                                </td>
                                <td width="2%" style="text-align:center; font-weight: bold; background-color:#1b497f; color:white;padding-top:10px; padding-bottom:10px; border-right:1px solid black;">

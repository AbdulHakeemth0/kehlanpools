<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Inherited view form of account.move.line-->
    <record id="view_move_form_sale_product_label" model="ir.ui.view">
        <field name="name">account.move.view.form.inherit.product.label</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/notebook/page[@id='invoice_tab']/field[@name='invoice_line_ids']/list/field[@name='product_id']" position="after">
                <field name="product_label"/>
            </xpath>
            
        </field>
    </record>
</odoo>

                                <t t-set="amount_total" t-value="0"/>
                                <t t-if="o.plan_id.is_quaterly">
                                    <t t-set="amount_total" t-value="o.amount_total/o.plan_id.billing_period_value"/>
                                    <t t-out="'{:.3f}'.format(amount_total)"/>
                                </t>
                                <t t-elif="o.plan_id.is_monthly">
                                    <t t-set="amount_total" t-value="o.amount_total/o.plan_id.billing_period_value"/>
                                    <t t-out="'{:.3f}'.format(amount_total)"/>
                                </t>
                                <t t-elif="o.plan_id.is_bi_yearly">
                                    <t t-set="amount_total" t-value="o.amount_total/o.plan_id.billing_period_value"/>
                                    <t t-out="'{:.3f}'.format(amount_total)"/>
                                </t>
                                <t t-elif="o.plan_id.is_yearly">

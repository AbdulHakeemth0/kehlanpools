<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <!-- Define the tree views for each model -->
        <record id="view_tree_detailed_specification_master" model="ir.ui.view">
            <field name="name">detailed.specification.master.tree</field>
            <field name="model">detailed.specification.master</field>
            <field name="arch" type="xml">
                <list>
                    <field name="description"/>
                </list>
            </field>
        </record>

         <record id="view_form_detailed_specification_master" model="ir.ui.view">
            <field name="name">detailed.specification.master.form</field>
            <field name="model">detailed.specification.master</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="specification_line_ids" widget="section_and_note_one2many">
                                <list editable="bottom">
                                    <control>
                                        <create name="add_line_control" string="Add a line"  context="{'default_display_type': 'line_item'}"/>
                                        <create name="add_section_control" string="Add a section"
                                                context="{'default_display_type': 'line_section'}"/>
                                         <create name="add_note_control" string="Add a note" context="{'default_display_type': 'line_note'}"/>

                                    </control>
                                    <field name="name"/>
                                    <field name="item"/>
                                    <field name="qty"/>
                                    <field name="uom_id"/>
                                    <field name="tax_id"/>
                                    <field name="amount"/>
                                     <field name="display_type"  column_invisible="True"/>
                                </list>
                            </field>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>


        <!-- Define the actions for the submenus -->
        <record id="action_detailed_specification_master" model="ir.actions.act_window">
            <field name="name">Detailed Specification</field>
            <field name="res_model">detailed.specification.master</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('active','=',True)]</field>
            <field name="domain">['|', ('active', '=', True), ('active', '=', False)]</field>
            <field name="view_id" ref="view_tree_detailed_specification_master"/>
            <field name="context">{}</field>
        </record>

        <!-- Submenu for Detailed Specification -->
        <!-- <menuitem id="menu_detailed_specification"
                  name="Detailed Specification "
                  parent="bi_amc_proposal.menu_vas_template2_details"
                  sequence="1"
                  action="action_detailed_specification_master"/> -->

    </data>
</odoo>
<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_product_amc_form" model="ir.ui.view">
        <field name="name">amc.plan.form</field>
        <field name="model">amc.plan</field>
        <field name="arch" type="xml">
            <form string="Amc Plan">
                <header>
                    <field name="state" widget="statusbar"/>

                    <button name="create_invoice" type="object" string="Create Invoice" class="btn-primary"/>
                    <button name="activate_plan" type="object" string="Active" class="btn-primary" invisible="state == 'active' or state == 'expired'"/>
                    <button name="cancel_plan" type="object" string="Cancel" class="btn-primary" invisible="state == 'draft' or state == 'expired' or state == 'cancel'"/>
                    <button name="expire_plan" type="object" string="Expired" class="btn-secondary" invisible="state == 'draft' or state == 'expired'"/>
                    <button name="renew_contract" type="object" string="Renew" class="btn-secondary" invisible="state == 'draft' or state == 'expired' or state == 'active'"/>
                </header>

                <sheet>
                    <div name="button_box" position="inside">
                        <button name="view_existing_amc" type="object" class="oe_stat_button" icon="fa-pencil-square-o">
                            <field name="amc_history_count" string="AMC History" widget="statinfo"/>
                        </button>
                        <button type="object"
                            name="action_view_button"
                            class="oe_stat_button"
                            icon="fa-file-text"
                              invisible="invoice_count == 0">
                            <field name="invoice_count" widget="statinfo" string="Invoices"/>
                        </button>
                    </div>

                    <div>
                        <widget name="web_ribbon" title="Expired" invisible="state == 'draft' or state == 'active' or state == 'cancel'" widget_id="widget_1"/>
                    </div>

                    <!-- <div class="oe_title">
                        <field name="invoice_id" options="{'no_create': True}" class="oe_inline" style="text-align: center;" nolabel="1"/>
                    </div> -->
    
                    <div class="row">
                        <div class="col-lg-6">
                            <group>
                                <field name="name" required="1" readonly="state == 'draft' or state == 'expired' or state == 'cancel' or state == 'active'"/>
                                <field name="customer_id" required="1" readonly="state == 'expired' or state == 'active'"/>
                                <field name="services_involved" required="1" widget="many2many_tags" readonly="state == 'expired' or state == 'active'"/>
                                <field name="sale_order_id" invisible="1"/>
                            </group>
                        </div>
                        <div class="col-lg-6">
                            <group>
                                <field name="recurring_interval_type" widget="selection" required="1" readonly="state == 'expired' or state == 'active'"/>
                                <field name="recurring_interval" readonly="state == 'expired' or state == 'active'"/>
                                <field name="recurring_period" required="1" invisible="1" readonly="state == 'expired' or state == 'active'"/>
                            </group>
                            <group>
                                <field name="start_date" readonly="state == 'expired' or state == 'active'"/>
                                <field name="next_maintenance_date" readonly="state == 'expired' or state == 'active'"/>
                                <field name="end_date" required="1" readonly="state == 'expired' or state == 'active'"/>
                            </group>
                        </div>
                    </div>
                    <group>
                        <field name="invoice_disable" invisible="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_product_amc_list" model="ir.ui.view">
        <field name="name">amc.plan.list</field>
        <field name="model">amc.plan</field>
        <field name="arch" type="xml">
            <list string="Maintenance Plans" create="0">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="next_maintenance_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_product_maintenance_search" model="ir.ui.view">
        <field name="name">amc.plan.search</field>
        <field name="model">amc.plan</field>
        <field name="arch" type="xml">
            <search>
                <field name='name'/>
                <field name='customer_id'/>
                    <separator/>
                    <filter string="Maintenance Plan Name" name="name" context="{'group_by':'name'}"/>
                    <filter string="Customer" name="customer_id" context="{'group_by':'customer_id'}"/>
                    <separator/>
            </search>
        </field>
    </record>    

    <record id="account_invoice_form_inherit" model="ir.ui.view">
        <field name="name">account.move.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="amc_plan_id" invisible="1"/>
            </xpath>  
        </field>
    </record>

    <record id="ir_cron_auto_create_invoice" model="ir.cron">
        <field name="name">Automatic Invoice Creation for Amc Plans</field>
        <field name="model_id" ref="model_amc_plan"/>
        <field name="state">code</field>
        <field name="code">model.action_cron_auto_create_invoice()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall" eval="(DateTime.now().replace(year=3000, hour=0, minute=0)).strftime('%Y-%m-%d %H:%M:%S')" />
        <field name="active">True</field>
    </record>

    <record id="action_amc_plan_invoices" model="ir.actions.act_window">
        <field name="name">Invoices</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('amc_plan_id', '!=', False)]</field>
        <field name="context">{}</field>
    </record>
</odoo>

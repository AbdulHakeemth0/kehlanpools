<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_project_form_inherit_view" model="ir.ui.view">
            <field name="name">project.form.inherited</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.edit_project"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet/div[2][hasclass('oe_title')]/h1" position="before">
                    <h1>
                        <field name="sequence_no" readonly="1"/>
                    </h1> 
                </xpath>
            </field>
        </record>
    </data>
</odoo>

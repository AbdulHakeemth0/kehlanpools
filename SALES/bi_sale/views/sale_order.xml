<?xml version="1.0"?>
<odoo>
    <record id="sale_order_custom_view_form" model="ir.ui.view">
        <field name="name">sale.order.form.custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list//field[@name='discount']"  position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="optional">hide</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="readonly">state in ['submitted','cancel','sale','sent','waiting','revise']</attribute>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="button_approved" type="object" string="Approve" groups="bi_vas_amc.group_vas_amc_confirm,bi_vas_amc.group_vas_confirm,bi_vas_amc.group_amc_confirm" invisible="state not in ['submitted']"/> 
                <button name="button_reject_request" type="object" string="Reject" invisible="state not in ['submitted']"/>
                
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="amc_sequence" readonly="1" invisible="1"/>
                <field name="m_number" readonly="state not in ['draft','submitted','approved']"/>
                <field name="external_project" invisible="type != 'amc'"  readonly="state not in ['draft']"/>
                <field name="job_number" invisible="not external_project or type != 'amc'"  readonly="state not in ['draft'] or is_revision" required="external_project"/>
                <field name="vas_job_number" invisible="external_project or type != 'amc'"  readonly="state not in ['draft'] or is_revision"/>
                <field name="team_lead_id" domain="[('id', 'in', team_lead_ids)]"  readonly="state not in ['draft','submitted','approved']"/>
                <field name="team_lead_ids" invisible="1"/>
                <field name="technician_ids" readonly="state not in ['draft']" widget="many2many_tags" invisible="1"/>
                <field name="members_ids" readonly="state not in ['draft','submitted','approved']" widget="many2many_tags" options="{'no_create': True, 'no_edit':True}" domain="[('id', 'in', technician_ids)]"/>
            </xpath>
            <xpath expr="//field[@name='team_id']" position="after">
                <field name="approved_by"/>
            </xpath>
            <!-- <xpath expr="//group[@name='order_details']" position="inside">
                    <div class="o_td_label">
                        <span name="m-number_span"><b>M-number: </b><field name="m_number" class="oe_inline"/></span>
                    </div>
            </xpath> -->
            <xpath expr="/form/sheet/notebook/page/field[@name='order_line']/list/field[@name='product_template_id']" position="after">
                <field name="struct_name" store="True" column_invisible="1"/>
                <field name="image" column_invisible="parent.type == 'amc'"/>
            </xpath>
            <xpath expr="/form/sheet/group[@name='sale_header']/group[@name='order_details']/field[@name='payment_term_id']" position="after">
                <field name="subject" required="1" readonly="state not in ['draft','submitted','approved','sale']"/>
                <!-- <field name="pool_type" invisible="type != 'amc'"/> -->
            </xpath>
            <xpath expr="//field[@name='validity_date']" position="before">
                <field name="pool_type" invisible="type != 'amc'"  readonly="state not in ['draft']"/>
            </xpath>
            <xpath expr="//field[@name='start_date']" position="after">
                <field name="reject_reason" readonly="1"/>
                <field name="rejected_by" readonly="1"/>
            </xpath>
            <xpath expr="//page[@name='other_information']" position="after">
                <page name="pool_specification" string="Pool Specification" invisible="type == 'vas'">
                    <group>
                        <group>
                            <field name="pool_functionality" store="True"/>
                            <field name="sub_pool_functionality" invisible="pool_functionality not in ['others']"/>
                        </group>
                        <group>
                            <field name="no_of_pools"/>

                        </group>
                    </group>
                    <field name="pool_specification_ids" invisible="type == 'vas'" readonly="state not in ['draft']">
                        <list editable="bottom" create="0">
                            <field name="pool_specification_sl_no" store="True"/>
                            <field name="area_of_pool" store="True"/>
                            <field name="location_of_pool" force_save="1" column_invisible="1"/>
                            <field name="pool_loc" force_save="1"/>
                            <field name="volume_of_water" store="True"/>
                            <field name="pool_filteration_system" store="True" column_invisible="1"/>
                            <field name="asset_location" store="True"/>
                            <field name="filteration_system" force_save="1"/>
                            <field name="auto_dozing_system" store="True"/>
                            <field name="disinfection_system" store="True"/>
                            <field name="pool_finishing_type" store="True"/>
                            <field name="age_of_pool" store="True"/>
                            <field name="distance_from_camp" store="True"/>
                            <field name="distance_from_other_pools" store="True"/>
                            <field name="pools_in_circuit" store="True"/>
                            <field name="visit_frequency" store="True"/>
                            <field name="visit_type" store="True"/>
                            <field name="sub_visit_type" readonly="0" invisible="visit_type not in ['others']"/>
                            <field name="accomodation" store="True"/>
                        </list>
                    </field>
                </page>
                <page name="pool_dimension" string="Pool Dimension" invisible="type == 'vas'" >
                    <field name="pool_dimension_ids" readonly="state not in ['draft']">
                        <list editable="bottom" create="0">
                            <field name="pool_dimension_sl_no" store="True"/>
                            <field name="length" store="True"/>
                            <field name="breadth" store="True"/>
                            <field name="pool_depth" store="True"/>
                            <field name="water_depth" store="True"/>
                            <field name="water_volume" store="True"/>
                            <field name="pool_surface_area" store="True"/>
                            <field name="coping_width" store="True"/>
                            <field name="coping_surface_area" store="True"/>
                            <field name="total_surface_area" store="True"/>
                        </list>
                    </field>
                </page>
                <page name="pricing_structure" string="Pricing Structure" invisible="type == 'vas'">
                    <group>
                        <group>
                            <field name="profit_margin_percentage" store="True"  readonly="state not in ('draft')"/>
                            <field name="company_over_head" store="True"  readonly="state not in ('draft')"/>
                        </group> 
                        <group>
                            <group>
                                <field name="no_of_line_manpower" store="True" invisible="1"/>
                                <field name="no_of_line_consumables" store="True" invisible="1"/>
                            </group>
                            <group>
                                <field name="no_of_line_toolsandequipments" store="True" invisible="1"/>
                                <field name="no_of_line_otheritems" store="True" invisible="1"/>
                            </group>
                        </group>
                    </group>
                    <field name="pricing_structure_ids" widget="section_and_note_one2many" readonly="state not in ('draft')">
                        <list limit="60" create="0" editable="bottom">
                            <control>
                                <create name="add_line_control" string="Add a line"/>
                                <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section'}"/>
                            </control>
                            <field name="display_type" column_invisible="True"/>
                            <field name="name"/>
                            <field name="pool_structure_sl_no" force_save="1" readonly="1" column_invisible="1"/>
                            <field name="is_manpower" column_invisible="True"/>
                            <field name="is_consumables" column_invisible="True"/>
                            <field name="is_toolsequipment" column_invisible="True"/>
                            <field name="is_otheritems" column_invisible="True"/>
                            <field name="is_sum_line" column_invisible="True"/>
                            <field name="item_master_id" readonly="is_sum_line" force_save="1" column_invisible="1"/>
                            <field name="out_of" readonly="is_sum_line" force_save="1" column_invisible="1"/>
                            <field name="description" readonly="is_sum_line" force_save="1"/>
                            <field name="unit" readonly="is_sum_line" force_save="1"/>
                            <field name="boq" readonly="is_sum_line" force_save="1"/>
                            <field name="unit_rate" readonly="is_sum_line" force_save="1"/>
                            <field name="amount" force_save="1"/>
                            <field name="total_amount" readonly="1" force_save="1" column_invisible="1"/>
                            <field name="remarks" readonly="is_sum_line" force_save="1"/>                     
                        </list>
                    </field>
                    <group>
                        <field name="pricing_structure_discount"  readonly="state not in ('draft')"/>
                    </group>
                    <group>
                        <group class="oe_subtotal_footer">
                            <field name="total_cost" readonly="1"/>
                            <field name="company_over_head" readonly="1" invisible="1"/>
                            <field name="over_head" readonly="1"/>
                            <field name="profit_margin" readonly="1"/>
                            <field name ="subtotal" readonly="1"/>
                            <field name="discount" readonly="1"/>
                            <field name="total_quote_amount" widget="monetary" class="h3" readonly="1"/>
                            <field name ="amount_tax_pricing_structure" readonly="1"/>
                            <field name="amount_total_with_tax" widget="monetary" class="h3"/>
                           
                        </group>
                    </group>
                </page>
                <page name="mep_equipment_specifications_sale" string="MEP Equipment Specifications" invisible="type == 'vas'">
                    <field name="mep_equipment_ids" widget="section_and_note_one2many" readonly="state not in ['draft']">
                        <list editable="bottom">
                            <control>
                                <create name="add_line_control" string="Add a line"/>
                                <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section'}"/>
                            </control>
                            <field name="equipment_id" store="True"/>
                            <field name="equipment_make" store="True"/>
                            <field name="equipment_qty" store="True"/>
                            <field name="equipment_type" store="True"/>
                            <field name="equipment_size" store="True"/>
                            <field name="image"/>
                        </list>
                    </field>
                </page>
                <page  name="sale_revision" string="Sale Revision">
                    <field name="sale_revision_ids" >
                        <list editable="bottom" create="0">
                            <field name="sale_order_history_id" store="True"/>
                        </list>
                    </field>
                </page>
                <page  name="chemicals_in_use" string="Chemicals in Use">
                    <field name="sale_chemical_use_line_ids" widget="section_and_note_one2many" readonly="state not in ['draft','submitted','approved']">
                        <list limit="60" create="1" editable="bottom">
                            <control>
                                <create name="add_line_control" string="Add a line"/>
                                <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section'}"/>
                            </control>
                            <field name="display_type" column_invisible="True"/>
                            <field name="name"/>
                            <field name="pool_structure_sl_no" force_save="1" column_invisible="0"/>
                        </list>
                    </field>
                </page>
                <page  name="manpower_provision" string="Manpower Provision">
                    <field name="sale_manpower_line_ids" widget="section_and_note_one2many" readonly="state not in ['draft','submitted','approved']">
                        <list limit="60" create="1" editable="bottom">
                            <control>
                                <create name="add_line_control" string="Add a line"/>
                                <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section'}"/>
                            </control>
                            <field name="display_type" column_invisible="True"/>
                            <field name="name"/>
                            <field name="pool_structure_sl_no" force_save="1"   column_invisible="0"/>
                        </list>
                    </field>
                </page>
            </xpath>
<!-- 
            <xpath expr="//page[@name='other_information']/group/group/field[@name='team_id']" position="after">
                <field name="team_lead_id"/>
                <field name="technician_ids" widget="many2many_tags" invisible="1"/>
                <field name="members_ids" widget="many2many_tags" options="{'no_create': True, 'no_edit':True}" domain="[('id', 'in', technician_ids)]"/>
            </xpath> -->
        </field>
    </record>

    <record id="sale_order_custom_view_filter" model="ir.ui.view">
        <field name="name">sale.order.form.custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">               
                <field name="m_number"/>
                <field string="Visit Frequency" name="pool_specification_ids" filter_domain="[('pool_specification_ids.visit_frequency', '=', self)]"/>
                <field string="Asset Location" name="pool_specification_ids" filter_domain="[('pool_specification_ids.asset_location', '=', self)]"/>
                <field string="Filtration System" name="pool_specification_ids" filter_domain="[('pool_specification_ids.filteration_system', '=', self)]"/>
                <field string="Pool Location" name="pool_specification_ids" filter_domain="[('pool_specification_ids.pool_loc', '=', self)]"/>
            </xpath>
            <filter name="my_sale_orders_filter" position="after">
                <separator/>
                <filter string="Indoor Location" name="asset_loc_indoor" domain="[('pool_specification_ids.asset_location', '=', 'indoor')]"/>
                <filter string="Outdoor Location" name="asset_loc_outdoor" domain="[('pool_specification_ids.asset_location', '=', 'outdoor')]"/>
                <!-- <filter string="Other Location" name="asset_loc_other" domain="[(pool_specification_ids.asset_location', '=', 'other')]"/> -->
                <filter string="filteration Firtrinov" name="filteration_firtrinov" domain="[('pool_specification_ids.filteration_system', '=', 'firtrinov')]"/>
                <filter string="filteration skimmer" name="filteration_skimmer" domain="[('pool_specification_ids.filteration_system', '=', 'skimmer')]"/>
                <filter string="filteration Overflow" name="filteration_overflow" domain="[('pool_specification_ids.filteration_system', '=', 'overflow')]"/>
                <filter string="filteration infinity" name="filteration_infinity" domain="[('pool_specification_ids.filteration_system', '=', 'infinity')]"/>
                <!-- <filter string="filteration Other" name="filteration_other" domain="[(pool_specification_ids.filteration_system', '=', 'other')]"/> -->
                <filter string="VIP Customers" name="cust_profile_vip" domain="[('partner_id.customer_profile', '=', 'vip')]"/>
                <filter string="General Customers" name="cust_profile_general" domain="[('partner_id.customer_profile', '=', 'general')]"/>
                <filter string="Individual Type Customers" name="cust_individual" domain="[('partner_id.customer_type', '=', 'individual')]"/>
                <filter string="Community type Customers" name="cust_community" domain="[('partner_id.customer_type', '=', 'community')]"/>
                <filter string="Hospitality Type Customers" name="cust_hospitality" domain="[('partner_id.customer_type', '=', 'hospitality')]"/>
                <filter string="Commericial Customers" name="cust_commercial" domain="[('partner_id.customer_type', '=', 'commercial')]"/>
                <filter string="Govt Customers" name="cust_govt" domain="[('partner_id.customer_type', '=', 'govt')]"/>
                <filter string="Visit Type-Weekly" name="visit_type_weekly" domain="[('pool_specification_ids.visit_type', '=', 'weekly')]"/>
                <filter string="Visit Type-Monthly" name="visit_type_monthly" domain="[('pool_specification_ids.visit_type', '=', 'monthly')]"/>
                <filter string="Visit Type-Yearly" name="visit_type_yearly" domain="[('pool_specification_ids.visit_type', '=', 'yearly')]"/>
            </filter>
        </field>    
    </record>
</odoo>

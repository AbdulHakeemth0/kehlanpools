<?xml version="1.0"?>
<odoo noupdate="1">
    <record id="whatsapp_template_invoice_attachment" model="whatsapp.template">
        <field name="name">Invoice Attachment</field>
        <field name="template_name">invoice_attachment</field>
        <field name="lang_code">en</field>
        <field name="template_type">utility</field>
        <field name="header_type">document</field>
        <field name="report_id" ref="account.account_invoices_without_payment"/>
        <field name="footer_text">Write 'stop' to stop receiving messages</field>
        <field name="phone_field">customer_id.phone</field>
        <field name="model_id" ref="bi_invoice_attachment.model_whatsapp_compose_message"/>
        <field name="body">Dear {{1}},

Here is your invoice
Thank you for your purchase.

Best Regards
        </field>
        <field name="variable_ids" eval="[
        (5, 0, 0),
        (0, 0, {
            'name': '{{1}}',
            'demo_value': 'demo',
            'line_type': 'body',
            'field_type': 'field',
            'field_name': 'attachment_ids'
        }),
        ]" />
    </record>
</odoo>

<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="fleet_vehicle_damage_history_view_form" model="ir.ui.view">
        <field name="name">fleet.vehicle.damage.history.form</field>
        <field name="model">fleet.vehicle.damages.history</field>
        <field name="arch" type="xml">
            <form string="Vehicle Damage History">
                <sheet>
                    <group>
                        <group>
                           <field name="date"/>
                           <field name="name"/>
                           <field name="comments"/>
                           <field name="view_type"/>
                           <field name="fleet_id"/>
                           <field name="model_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="fleet_vehicle_damage_history_list" model="ir.ui.view">
        <field name="name">damage.history.list</field>
        <field name="model">fleet.vehicle.damages.history</field>
        <field name="arch" type="xml">
            <list string="Damage History">
                <field name="date"/>
                <field name="name"/>
                <field name="comments"/>
                <field name="view_type"/>
            </list>
        </field>
    </record>

    <record id="fleet_vehicle_damage_history_search" model="ir.ui.view">
        <field name="name">damage.history.search</field>
        <field name="model">fleet.vehicle.damages.history</field>
        <field name="arch" type="xml">
            <search string="Search Damage History">
                <field name="view_type"/>
                <filter string="Front View" name="view_type" domain='[("view_type", "=", "front")]' />
                <filter string="Right Side View" name="view_type" domain="[('view_type', '=', 'right')]" />
                <filter string="Left Side View" name="view_type" domain="[('view_type', '=', 'left')]" />
                <filter string="Rear View" name="view_type" domain="[('view_type', '=', 'rear')]" />
                <group expand="0" string="Group By">
                    <filter string="View Type" name="groupby_view_type" context="{'group_by':'view_type'}" />
                </group>
            </search>
        </field>
    </record>

    <record id='fleet_vehicle_damage_history_action' model='ir.actions.act_window'>
        <field name="name">Damage History Master</field>
        <field name="res_model">fleet.vehicle.damages.history</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="fleet_vehicle_damage_history_list"/>
    </record>



</odoo>

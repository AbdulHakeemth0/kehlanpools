<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--Set up a cron job to send reminders for document expiry dates.-->
        <record id="fleet_documents_reminder" model="ir.cron">
            <field name="name">Fleet Documents Expiration</field>
            <field name="model_id" ref="model_vehicle_document"/>
            <field name="state">code</field>
            <field name="code">model.fleet_doc_mail_reminder()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
        </record>
    </data>
</odoo>

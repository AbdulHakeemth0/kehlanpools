<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="fleet_vehicle_view_form" model="ir.ui.view">
        <field name="name">fleet.vehicle.form</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//page[@name='note']" position='after'>

                <page name="other" string="Damages">

                    <div class="row">
                        <!-- First Image and Damage Section -->
                        <group string="Front View" style="text-align: center;">
                            <div class="col-12">
                                <div class="image-damage">
                                    <div class="image-container">
                                        <field name="image_1" widget="image" options="{'size': [800, 800]}"/>
                                    </div>
                                </div>
                                <div class="damage-container">
                                    <field name="image_1_damage_ids" nolabel="1" colspan="2">
                                        <list editable="bottom">
                                            <field name="date"/>
                                            <field name="name"/>
                                            <field name="comments"/>
                                        </list>
                                    </field>
                                </div>
                            </div>
                        </group>
                        <!-- Second Image and Damage Section -->
                        <group string="Right Side view" style="text-align: center;">
                            <div class="col-12">
                                <div class="image-damage">
                                    <div class="image-container">
                                        <field name="image_2" widget="image" options="{'size': [800, 800]}"/>
                                    </div>
                                </div>
                                <div class="damage-container">
                                    <field name="image_2_damage_ids" nolabel="1" colspan="2">
                                        <list editable="bottom">
                                            <field name="date"/>
                                            <field name="name"/>
                                            <field name="comments"/>
                                        </list>
                                    </field>
                                </div>
                            </div>
                        </group>
                        <!-- Third Image and Damage Section -->
                        <group string="Left Side view" style="text-align: center;">
                           <div class="col-12">
                                <div class="image-damage">
                                    <div class="image-container">
                                        <field name="image_3" widget="image" options="{'size': [800, 800]}"/>
                                    </div>
                                </div>
                                <div class="damage-container">
                                    <field name="image_3_damage_ids" nolabel="1" colspan="2">
                                        <list editable="bottom">
                                            <field name="date"/>
                                            <field name="name"/>
                                            <field name="comments"/>
                                        </list>
                                    </field>
                                </div>
                            </div>
                        </group>
                        <!-- Fourth Image and Damage Section -->
                        <group string="Rear view" style="text-align: center;">
                            <div class="col-12">
                                <div class="image-damage">
                                    <div class="image-container">
                                        <field name="image_4" widget="image" options="{'size': [800, 800]}"/>
                                    </div>
                                </div>
                                <div class="damage-container">
                                    <field name="image_4_damage_ids" nolabel="1" colspan="2">
                                        <list editable="bottom">
                                            <field name="date"/>
                                            <field name="name"/>
                                            <field name="comments"/>
                                        </list>
                                    </field>
                                </div>
                            </div>
                        </group>
                    </div>

                </page>
            </xpath>
            <xpath expr="//field[@name='vin_sn']" position='after'>
                <field name="starting_odometer" readonly="0" />
            </xpath>
        </field>
    </record>

    <record id='fleet_vehicle_view_form_inherit_documents_fleet_custom' model='ir.ui.view'>
        <field name="name">fleet.vehicle.form.inherit.documents.fleet</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="documents_fleet.fleet_vehicle_view_form_inherit_documents_fleet"/>
        <field name="arch" type="xml">
            <xpath expr="//div/field[@name='documents_fleet_settings']" position="replace">
            </xpath>

            <xpath expr="//button[@name='action_open_attachments']" position="replace">
                <button class="oe_stat_button" name="action_attachments" type="object" icon="fa-file-text-o">
                    <field string="Documents" name="documents_count" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
